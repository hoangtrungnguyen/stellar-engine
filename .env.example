# Stellar Engine — sandbox environment template
# Copy to .env and fill in real values. .env is gitignored.
#
#   cp .env.example .env
#   # then edit .env with real keys
#
# To load into shell:
#   set -a; source .env; set +a

# ── Plane (sandbox workspace) ─────────────────────────────────────────────────
PLANE_WORKSPACE=stellar-sandbox
PLANE_HOST=https://api.plane.so
PLANE_API_TOKEN=plane_api_REPLACE_ME

# Sandbox project ID used by generator + task-generator verification
PLANE_PROJECT_ID=STELL

# ── Anthropic (generator LLM step) ────────────────────────────────────────────
# Not needed today: Claude Code subscription covers interactive use.
# Required only when generator's `llm_client.py` (Phase D+) makes direct SDK calls.
# Leave as REPLACE_ME until Phase D is reached.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Sandbox target repo (used by integration tests) ───────────────────────────
SANDBOX_REPO=/Users/trungnguyenhoang/IdeaProjects/stellar-sand-box

# ── Stellar engine home (for grava agent hooks) ───────────────────────────────
STELLAR_ENGINE_HOME=/Users/trungnguyenhoang/IdeaProjects/stellar-engine
