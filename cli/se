def _orch_pick_ids(team: str, target_repo: str, limit: int) -> list[str]:
    """Run pick_ready.py as a subprocess and return the issue IDs.

    Subprocess (not in-process) so we get a clean JSON capture on stdout —
    pick_ready writes a JSON array and we need to parse it after each
    call without interfering with other module-level state.
    """
    script = _orch_script("pick_ready.py")
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        return []
    r = subprocess.run(
        [sys.executable, str(script),
         "--team", team, "--target-repo", target_repo,
         "--limit", str(limit)],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        print(f"pick_ready({team}) failed: {r.stderr.strip()}", file=sys.stderr)
        return []
    try:
        items = json.loads(r.stdout or "[]")
    except json.JSONDecodeError:
        return []
    return [it.get("id", "") for it in items if it.get("id")]


def _orch_route(issue_id: str, target_repo: str) -> tuple[int, dict]:
    """Run route.py as a subprocess; return (exit_code, route_info_dict).

    Subprocess so we can capture the JSON output without consuming sys.exit
    inside the loop.
    """
    route_script = _orch_script("route.py")
    if not route_script.exists():
        print(f"ERROR: {route_script} not found", file=sys.stderr)
        return 1, {}
    r = subprocess.run(
        [sys.executable, str(route_script),
         issue_id, "--target-repo", target_repo],
        capture_output=True, text=True,
    )
    print(r.stdout, end="")
    if r.stderr:
        print(r.stderr, end="", file=sys.stderr)
    if r.returncode != 0:
        return r.returncode, {}
    try:
        return 0, json.loads(r.stdout.strip().splitlines()[-1])
    except (json.JSONDecodeError, IndexError):
        print("ERROR: could not parse route.py output", file=sys.stderr)
        return 2, {}


def _orch_dispatch_phase0(issue_id: str, team: str, target_repo: str) -> int:
    """Fire Phase 0 for resolved team. Returns dispatch exit code.

    Uses subprocess (not _orch_invoke) so a single-issue dispatch does
    not call sys.exit and prematurely terminate the --all loop.
    """
    if team == "fix-bug":
        script_name = "fix_bug_claim.py"
    elif team == "qa":
        script_name = "qa_load.py"
    elif team == "task-generator":
        script_name = "task_gen_expand.py"
    elif team == "epic-task":
        print(
            f"  Team 'epic-task' (task/story/subtask) currently runs via "
            f"the /ship slash command in Claude Code — no `se` equivalent yet.\n"
            f"  Run inside the target repo:  claude  →  /ship {issue_id}",
            file=sys.stderr,
        )
        return 0
    else:
        print(f"ERROR: unknown team '{team}'", file=sys.stderr)
        return 1

    script = _orch_script(script_name)
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        return 1
    r = subprocess.run(
        [sys.executable, str(script), issue_id, "--target-repo", target_repo],
    )
    return r.returncode


def cmd_orchestrator_deploy(args: argparse.Namespace) -> None:
    """Composite: route (or pick) → Phase 0 entry for the resolved team.

    Three modes:
    - With <id>: route the issue, then fire the team's Phase 0 step.
    - Without <id>, no --all: pick next ready item for --team (or scan
      all teams), then route + dispatch a single issue.
    - With --all --team T: loop over every ready issue for team T
      (capped by --limit, default 100), routing + dispatching each.
      Default behaviour is continue-on-error; pass --stop-on-error
      to bail on the first failure.

    Multi-phase pipelines (fix-bug, QA) only get Phase 0 here. Operator
    drives subsequent phases (verify, pr, report) manually with
    `se o fix-bug verify|pr` / `se o qa report`.
    """
    _apply_plane_profile_env(args)
    target_repo = args.target_repo

    # ── Mode 3: --all batch loop ─────────────────────────────────────────
    if args.all:
        if args.id:
            print("ERROR: --all cannot be combined with <id>", file=sys.stderr)
            sys.exit(2)
        if not args.team:
            print("ERROR: --all requires --team T", file=sys.stderr)
            sys.exit(2)

        team = args.team

        # Guard: only batch-valid teams (agent-teams with a Phase 0 script,
        # plus hint-only teams that loop and print /ship hints) are allowed.
        # Anything outside _BATCH_TEAMS is rejected with exit 0.
        if team not in _BATCH_TEAMS:
            print(
                f"Team '{team}' is not a valid batch target — no Phase 0 "
                f"dispatch or /ship hint loop available from `se` "
                f"(valid teams: {', '.join(_BATCH_TEAMS)}).\nNothing to do.",
                file=sys.stderr,
            )
            sys.exit(0)

        hint_only = team in _HINT_ONLY_TEAMS

        limit = args.limit or 100
        ids = _orch_pick_ids(team, target_repo, limit)

        # Empty-queue report — distinct from per-issue summary so the
        # operator gets a clear "nothing to dispatch" signal.
        if not ids:
            print(f"── Empty queue report (team={team}) ──")
            print(f"  repo:   {target_repo}")
            print(f"  ready:  0 issues")
            print(f"  hint:   inspect in-flight items with "
                  f"`se o pick --team {team} --target-repo {target_repo}` "
                  f"and `grava list` in the repo.")
            if hint_only:
                print(f"  note:   nothing hinted; team={team} loops emit "
                      f"`/ship <id>` hints but require Claude Code to actually "
                      f"ship.")
            else:
                print(f"  note:   nothing dispatched; no Phase 0 fired.")
            sys.exit(0)

        verb = "hint" if hint_only else "dispatch"
        print(f"Batch {verb}: team={team}, {len(ids)} issue(s) ready "
              f"(limit={limit}).")
        if args.dry_run:
            for iid in ids:
                if hint_only:
                    print(f"  [dry-run] would print /ship hint for {iid} "
                          f"(team={team}, runs in Claude Code)")
                else:
                    print(f"  [dry-run] would dispatch {iid} to team={team} Phase 0")
            sys.exit(0)

        dispatched: list[str] = []
        hinted: list[str] = []
        failed: list[tuple[str, int]] = []

        for idx, iid in enumerate(ids, start=1):
            print(f"\n[{idx}/{len(ids)}] {iid}")
            rc, route_info = _orch_route(iid, target_repo)
            if rc != 0:
                failed.append((iid, rc))
                if args.stop_on_error:
                    break
                continue

            routed_team = route_info.get("team", "")
            # Silent skip: if the picked issue doesn't actually belong to
            # the requested team (rare — labels changed since pick_ready
            # ran), do nothing. No log row, no count.
            if routed_team != team:
                continue

            if hint_only:
                # _orch_dispatch_phase0 prints the /ship hint for epic-task
                # and returns 0 — call it for uniform behaviour, but bucket
                # the result as "hinted" rather than "dispatched" so the
                # summary clearly distinguishes the two.
                print(f"→ Hint: {iid} (team={team}, run in Claude Code)")
                rc = _orch_dispatch_phase0(iid, team, target_repo)
                if rc == 0:
                    hinted.append(iid)
                else:
                    failed.append((iid, rc))
                    if args.stop_on_error:
                        break
                continue

            print(f"→ Dispatching {iid} to team={team} (Phase 0)")
            rc = _orch_dispatch_phase0(iid, team, target_repo)
            if rc == 0:
                dispatched.append(iid)
            else:
                failed.append((iid, rc))
                if args.stop_on_error:
                    break

        # Batch summary
        print(f"\n── Batch summary (team={team}) ──")
        if hint_only:
            print(f"  hinted:     {len(hinted)}  "
                  f"failed: {len(failed)}  "
                  f"of {len(ids)} candidates")
            if hinted:
                print(f"  next:       run each in Claude Code:")
                for iid in hinted:
                    print(f"                /ship {iid}")
        else:
            print(f"  dispatched: {len(dispatched)}  "
                  f"failed: {len(failed)}  "
                  f"of {len(ids)} candidates")
        for iid, rc in failed:
            print(f"  failed {iid}: exit={rc}")
        if not dispatched and not hinted and not failed:
            # All candidates silently skipped (route mismatch).
            print(f"  note:       none of the {len(ids)} candidates routed to "
                  f"team={team}; nothing dispatched.")
        sys.exit(0 if not failed else 1)

    # ── Mode 1 / 2: single-issue dispatch ────────────────────────────────
    issue_id = args.id
    if not issue_id:
        # Auto-pick from one team or scan all four teams (priority order)
        teams = [args.team] if args.team else [
            "fix-bug", "epic-task", "qa", "task-generator",
        ]
        for team in teams:
            picked = _orch_pick_ids(team, target_repo, 1)
            if picked:
                issue_id = picked[0]
                print(f"Auto-picked from team={team}: {issue_id}")
                break
        if not issue_id:
            print(
                f"No ready issues found for "
                f"{'team='+args.team if args.team else 'any team'} in {target_repo}.",
                file=sys.stderr,
            )
            sys.exit(1)

    rc, route_info = _orch_route(issue_id, target_repo)
    if rc != 0:
        sys.exit(rc)

    team = route_info.get("team", "")
    if args.team and args.team != team:
        print(
            f"WARNING: --team={args.team} but routing classified {issue_id} as "
            f"{team}. Using {team}.",
            file=sys.stderr,
        )
    if args.dry_run:
        print(f"[dry-run] Would dispatch {issue_id} to team={team} Phase 0.")
        sys.exit(0)

    print(f"\n→ Dispatching {issue_id} to team={team} (Phase 0)")
    sys.exit(_orch_dispatch_phase0(issue_id, team, target_repo))


