    # `grava` modules that run.py loads via `import write as write_cli`.
    for p in (str(tg_root), str(tg_cli)):
        if p not in sys.path:
            sys.path.insert(0, p)

    _apply_plane_profile_env(args)
    mod = _load_module("taskgen_run", script)

    argv = [args.project_id, args.page_id]
