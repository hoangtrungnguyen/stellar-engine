# ── version (overwritten by scripts/build.sh at build time) ───────────────────
def _load_version() -> tuple[str, str, str]:
    """Load (__version__, __commit__, __build_date__) from cli/_version.py.

    Falls back gracefully if the file is absent.
    """
    import importlib.util
    here = Path(__file__).resolve().parent
    vfile = here / "_version.py"
    if not vfile.exists():
        meipass = getattr(sys, "_MEIPASS", None)
        if meipass:
            vfile = Path(meipass) / "cli" / "_version.py"
    if not vfile.exists():
        return ("0.0.0-dev", "unknown", "unknown")
    spec = importlib.util.spec_from_file_location("_version", vfile)
    if spec is None or spec.loader is None:
        return ("0.0.0-dev", "unknown", "unknown")
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return (
        getattr(mod, "__version__", "0.0.0-dev"),
        getattr(mod, "__commit__", "unknown"),
        getattr(mod, "__build_date__", "unknown"),
    )


SE_VERSION, SE_COMMIT, SE_BUILD_DATE = _load_version()


