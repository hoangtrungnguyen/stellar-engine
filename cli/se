#
# Thin wrapper around agents/task-generator/cli/run.py — the three-phase
# end-to-end orchestrator:
#
#   Phase 1  preview     parse Plane spec page → epic/story/task plan
#                        (markdown previews under runs/preview/<RID>/).
#   Phase 2  Plane       create Plane work items + `blocking` relations.
#   Phase 3  Grava       mirror the hierarchy into the target repo's grava DB.
#
# Each destructive phase prompts the operator unless --yes is set; --dry-run
# stops after Phase 1 with no writes. The target repo is resolved via
# repo-map.yaml (Plane UUID → repo, auto-cloned if missing) unless overridden
# by --target-repo.
#
#   se taskgen <PROJECT_UUID> <PAGE_UUID> --dry-run   # preview only
#   se taskgen <PROJECT_UUID> <PAGE_UUID> --yes       # full pipeline
#
# We dispatch via importlib (same in-process pattern as cmd_generate /
# cmd_plane_sync) so the PyInstaller bundle can call into the agents/ data
# bundle without spawning subprocess(sys.executable, …) — which would
# re-enter the `se` entrypoint, not run.py.


def cmd_taskgen(args: argparse.Namespace) -> None:
    """Invoke agents/task-generator/cli/run.main directly.

    Wraps the task-generator end-to-end orchestrator: Plane page →
    Plane work items (epic/story/task) + blocking deps → Grava mirror
