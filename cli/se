    )
    p_orch_pick.add_argument("--limit", type=int, default=1)
    p_orch_pick.add_argument("--target-repo", default=".", metavar="PATH")

    # se orchestrator doctor
    p_orch_doc = orch_sub.add_parser(
        "doctor",
        help="Verify env for orchestrator sub-pipelines + grava→Plane sync",
    )
    p_orch_doc.add_argument("--target-repo", default=".", metavar="PATH")
    p_orch_doc.add_argument("--json", action="store_true")
    _add_plane_profile_flags(p_orch_doc)

    # se orchestrator expand <epic-id>
    p_orch_exp = orch_sub.add_parser(
        "expand",
        help="Resolve a grava epic's Plane page and delegate to task-generator",
    )
    p_orch_exp.add_argument("epic_id", help="Grava epic issue ID")
    p_orch_exp.add_argument("--target-repo", default=".", metavar="PATH")
    p_orch_exp.add_argument("--dry-run", action="store_true",
                            help="task-generator Phase A preview only")
    _add_plane_profile_flags(p_orch_exp)

    # se orchestrator deploy [<id>] [--team T]
    p_orch_dep = orch_sub.add_parser(
        "deploy",
        help="Route + fire Phase 0 for an issue (auto-picks if <id> omitted; "
             "use --all to batch over an entire team)",
    )
    p_orch_dep.add_argument("id", nargs="?", default=None,
                            help="Grava issue ID. Omit to auto-pick.")
    p_orch_dep.add_argument(
        "--team", default=None,
        choices=("fix-bug", "epic-task", "qa", "task-generator"),
        help="Filter for auto-pick / required for --all. "
             "Ignored when <id> is given (route decides).",
    )
    p_orch_dep.add_argument("--target-repo", default=".", metavar="PATH")
    p_orch_dep.add_argument("--dry-run", action="store_true",
                            help="Route only — do not fire Phase 0")
    p_orch_dep.add_argument("--all", action="store_true",
                            help="Loop over every ready issue for --team T, "
                                 "firing Phase 0 for each. Requires --team. "
                                 "Default: continue on per-issue errors.")
    p_orch_dep.add_argument("--limit", type=int, default=None,
                            help="Max issues to pick when --all is set "
                                 "(default: 100). Ignored otherwise.")
    p_orch_dep.add_argument("--stop-on-error", action="store_true",
                            help="With --all: bail at the first per-issue "
                                 "failure instead of continuing.")
    _add_plane_profile_flags(p_orch_dep)

    # se orchestrator fix-bug {claim,verify,pr}
    p_orch_fb = orch_sub.add_parser("fix-bug", help="Fix-bug pipeline phases")
    fb_sub = p_orch_fb.add_subparsers(dest="fb_cmd", metavar="PHASE")
    fb_sub.required = True

    p_fb_claim = fb_sub.add_parser("claim", help="Phase 0: claim bug + provision worktree")
    p_fb_claim.add_argument("id", help="Grava bug issue ID")
    p_fb_claim.add_argument("--target-repo", default=".", metavar="PATH")
    p_fb_claim.add_argument("--actor", default=None)

    p_fb_ver = fb_sub.add_parser("verify", help="Phase 2: self-verify (tests/lint/build)")
    p_fb_ver.add_argument("id", help="Grava bug issue ID")
    p_fb_ver.add_argument("--target-repo", default=".", metavar="PATH")
    p_fb_ver.add_argument("--skip-verify", action="store_true",
                          help="Force PASS verdict without running checks")
    p_fb_ver.add_argument("--actor", default=None)
    p_fb_ver.add_argument("--state-file", default=None, metavar="PATH")

    p_fb_pr = fb_sub.add_parser("pr", help="Phase 3: push branch + open PR")
    p_fb_pr.add_argument("id", help="Grava bug issue ID")
    p_fb_pr.add_argument("--target-repo", default=".", metavar="PATH")
    p_fb_pr.add_argument("--actor", default=None)
    p_fb_pr.add_argument("--title", default=None)
    p_fb_pr.add_argument("--draft", action="store_true")

    # se orchestrator qa {load,report}
    p_orch_qa = orch_sub.add_parser("qa", help="QA pipeline phases")
    qa_sub = p_orch_qa.add_subparsers(dest="qa_cmd", metavar="PHASE")
    qa_sub.required = True

    p_qa_load = qa_sub.add_parser("load", help="Phase 0: resolve + stage checklist")
    p_qa_load.add_argument("id", help="Grava issue ID")
    p_qa_load.add_argument("--target-repo", default=".", metavar="PATH")
    p_qa_load.add_argument("--checklist", default=None, metavar="PATH")
    p_qa_load.add_argument("--type", default=None,
                           choices=("cli", "api", "web", "mobile"))
    p_qa_load.add_argument("--out", default=None, metavar="PATH")

    p_qa_rep = qa_sub.add_parser("report", help="Phase 2: render + post QA report")
    p_qa_rep.add_argument("id", help="Grava issue ID")
    p_qa_rep.add_argument("--results-file", required=True, metavar="PATH")
    p_qa_rep.add_argument("--target-repo", default=".", metavar="PATH")
    p_qa_rep.add_argument("--actor", default=None)

    args = parser.parse_args()

    # Two-level dispatch for `orchestrator <sub>` (alias: `o`)
    if args.cmd in ("orchestrator", "o"):
        orch_table = {
            "route":  cmd_orchestrator_route,
            "pick":   cmd_orchestrator_pick,
            "doctor": cmd_orchestrator_doctor,
            "expand": cmd_orchestrator_expand,
            "deploy": cmd_orchestrator_deploy,
        }
        if args.orch_cmd in orch_table:
            orch_table[args.orch_cmd](args)
            return
        if args.orch_cmd == "fix-bug":
            {
                "claim":  cmd_orchestrator_fix_bug_claim,
                "verify": cmd_orchestrator_fix_bug_verify,
                "pr":     cmd_orchestrator_fix_bug_pr,
            }[args.fb_cmd](args)
            return
        if args.orch_cmd == "qa":
            {
                "load":   cmd_orchestrator_qa_load,
                "report": cmd_orchestrator_qa_report,
            }[args.qa_cmd](args)
            return

    {
        "init": cmd_init,
        "repos": cmd_repos,
        "doctor": cmd_doctor,
        "download": cmd_download,
        "generate": cmd_generate,
        "taskgen": cmd_taskgen,
        "plane-sync": cmd_plane_sync,
    }[args.cmd](args)


if __name__ == "__main__":
    main()
