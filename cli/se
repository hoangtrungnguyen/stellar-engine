# ── version (overwritten by scripts/build.sh at build time) ───────────────────
def _load_version() -> tuple[str, str, str]:
    """Load (__version__, __commit__, __build_date__) from cli/_version.py.

    Falls back gracefully if the file is absent.
    """
    import importlib.util
    here = Path(__file__).resolve().parent
    vfile = here / "_version.py"
    if not vfile.exists():
        meipass = getattr(sys, "_MEIPASS", None)
        if meipass:
            vfile = Path(meipass) / "cli" / "_version.py"
    if not vfile.exists():
        return ("0.0.0-dev", "unknown", "unknown")
    spec = importlib.util.spec_from_file_location("_version", vfile)
    if spec is None or spec.loader is None:
        return ("0.0.0-dev", "unknown", "unknown")
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return (
        getattr(mod, "__version__", "0.0.0-dev"),
        getattr(mod, "__commit__", "unknown"),
        getattr(mod, "__build_date__", "unknown"),
    )


SE_VERSION, SE_COMMIT, SE_BUILD_DATE = _load_version()


# ── .env auto-load ────────────────────────────────────────────────────────────
#
# Every `se` subcommand except `init` calls `_load_dotenv_if_present()` at
# the start of `main()`, so operators can drop credentials in a single
# `<engine-root>/.env` file instead of sourcing it manually each shell
# (the old `set -a; source .env; set +a` recipe still works — auto-load
# never overrides values already set in the shell environment).
#
# Lookup order (first match wins):
#   1. $STELLAR_ENGINE_HOME/.env   (only when STELLAR_ENGINE_HOME is set)
#   2. <cwd>/.env                  (typical operator pattern: run from engine root)
#
# We deliberately do NOT walk parent directories — that would risk picking up
# unrelated `.env` files (e.g. an OS-level one in $HOME or a target-repo `.env`)
# and silently injecting their contents into a Plane API call.


def _apply_dotenv(path: Path) -> None:
    """Parse a `.env` file at `path` and populate `os.environ`.

    Supports the common dotenv subset:
      - blank lines and `#` comments
      - `KEY=value`, `KEY="value"`, `KEY='value'`
      - optional leading `export ` (so the file is also valid for `source`)
      - inline `# comment` on unquoted values (must be preceded by whitespace)

    Existing `os.environ` values are NEVER overridden — shell-set vars win
    over file-set vars, matching python-dotenv's default. Malformed lines
    are silently skipped (so a broken line doesn't break every `se` call).
    """
    try:
        text = path.read_text()
    except OSError:
        return
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[len("export "):].lstrip()
        if "=" not in line:
            continue
        key, _, value = line.partition("=")
        key = key.strip()
        # Reject anything that isn't a plain identifier — guards against
        # garbage like `foo bar=baz` silently setting `foo bar`.
        if not key or not all(c.isalnum() or c == "_" for c in key) or key[0].isdigit():
            continue
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in ('"', "'"):
            value = value[1:-1]
        else:
            for i, ch in enumerate(value):
                if ch == "#" and (i == 0 or value[i - 1].isspace()):
                    value = value[:i].rstrip()
                    break
        if key in os.environ:
            continue
        os.environ[key] = value


def _load_dotenv_if_present() -> Path | None:
    """Auto-load `.env` from the engine root if present.

    Returns the loaded path (for visibility in tests / future logging),
    or None when no `.env` is found in any candidate location.
    """
    candidates: list[Path] = []
    home = os.environ.get("STELLAR_ENGINE_HOME")
    if home:
        candidates.append(Path(home) / ".env")
    candidates.append(Path.cwd() / ".env")
    for path in candidates:
        if path.is_file():
            _apply_dotenv(path)
            return path
    return None


