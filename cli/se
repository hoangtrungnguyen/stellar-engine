def _repo_root() -> Path:
    """Locate the bundled repo root.

    In dev: cli/se sits next to download_project_pages.py and agents/.
    In a PyInstaller --onefile bundle: data files are extracted to
    sys._MEIPASS; everything is bundled flat under that root.
    """
    meipass = getattr(sys, "_MEIPASS", None)
    if meipass:
        return Path(meipass)
    return Path(__file__).resolve().parent.parent


def _load_module(name: str, file_path: Path):
    """Load a Python file as a module without requiring package structure."""
    import importlib.util
    spec = importlib.util.spec_from_file_location(name, file_path)
    if spec is None or spec.loader is None:
        raise ImportError(f"cannot load {file_path}")
    module = importlib.util.module_from_spec(spec)
    sys.modules[name] = module
    spec.loader.exec_module(module)
    return module


def cmd_download(args: argparse.Namespace) -> None:
    """Invoke download_project_pages.main directly."""
    script = _repo_root() / "download_project_pages.py"
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        sys.exit(1)

    mod = _load_module("download_project_pages", script)
    argv = [args.project_id, "--output-root", args.output_root]
    if getattr(args, "page_id", None):
        argv += ["--page-id", args.page_id]
    if args.dry_run:
        argv.append("--dry-run")
    sys.exit(mod.main(argv))


def _resolve_plane_source(args: argparse.Namespace) -> str:
    """When --plane-project + --plane-page are set, download the page
    and return the local markdown path. Otherwise return args.source.

    Validates flag combinations and exits with a clear message on
    misuse before invoking the generator pipeline.
    """
    has_plane = bool(args.plane_project) and bool(args.plane_page)
    has_any_plane = bool(args.plane_project) or bool(args.plane_page)
    if has_any_plane and not has_plane:
        print(
            "ERROR: --plane-project and --plane-page must be used together.",
            file=sys.stderr,
        )
        sys.exit(1)
    if args.source and has_plane:
        print(
            "ERROR: pass either a local source path OR "
            "--plane-project + --plane-page, not both.",
            file=sys.stderr,
        )
        sys.exit(1)
    if not args.source and not has_plane:
        print(
            "ERROR: need a source — pass a markdown path or "
            "--plane-project <code> --plane-page <uuid>.",
            file=sys.stderr,
        )
        sys.exit(1)
    if not has_plane:
        return args.source

    # Plane mode — fetch the single page via download_project_pages.
    script = _repo_root() / "download_project_pages.py"
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        sys.exit(1)
    dl = _load_module("download_project_pages", script)
    cfg = dl.load_config()
    project_uuid, project_code = dl.resolve_project(cfg, args.plane_project)
    out_path = dl.download_single_page(
        cfg, project_uuid, project_code, args.plane_page,
        output_root="systems",
    )
    return str(out_path)


