def _repo_root() -> Path:
    """Locate the bundled repo root.

    In dev: cli/se sits next to download_project_pages.py and agents/.
    In a PyInstaller --onefile bundle: data files are extracted to
    sys._MEIPASS; everything is bundled flat under that root.
    """
    meipass = getattr(sys, "_MEIPASS", None)
    if meipass:
        return Path(meipass)
    return Path(__file__).resolve().parent.parent


def _load_module(name: str, file_path: Path):
    """Load a Python file as a module without requiring package structure."""
    import importlib.util
    spec = importlib.util.spec_from_file_location(name, file_path)
    if spec is None or spec.loader is None:
        raise ImportError(f"cannot load {file_path}")
    module = importlib.util.module_from_spec(spec)
    sys.modules[name] = module
    spec.loader.exec_module(module)
    return module


def cmd_download(args: argparse.Namespace) -> None:
    """Invoke download_project_pages.main directly.

    Default-public-only: the underlying script filters out pages whose
    `access` field is set to 1 (private). Operators who need the older
    "download every page" behaviour pass --include-private through.
    """
    script = _repo_root() / "download_project_pages.py"
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        sys.exit(1)

    mod = _load_module("download_project_pages", script)
    argv = [args.project_id, "--output-root", args.output_root]
    if getattr(args, "page_id", None):
        argv += ["--page-id", args.page_id]
    if getattr(args, "page_name", None):
        argv += ["--page-name", args.page_name]
    if args.dry_run:
        argv.append("--dry-run")
    if getattr(args, "include_private", False):
        argv.append("--include-private")
    sys.exit(mod.main(argv))


# ── se pages ──────────────────────────────────────────────────────────────────
#
# `se pages <project>` lists every page in a Plane project. Read-only.
#
# Reuses the helpers in `download_project_pages.py` (load_config,
# resolve_project, list_pages, is_public_page) by importing the module
# in-process instead of shelling out — listing has no side effects, so
# there's no reason to spawn a subprocess for it.
#
# Default = public pages only (matches `se download`). `--include-private`
# widens the listing to private (access=1) pages. `--json` switches the
# output from a fixed-width table to a JSON array of {id, name, access}
# for script consumers.


def _se_pages_format_access(page: dict) -> str:
    """Render the access bit as `public` / `private` / `unknown`.

    Older Plane schemas may omit the field — surface that as `unknown`
    so operators can spot drift between server versions.
    """
    access = page.get("access")
    if access is None:
        return "unknown"
    return "public" if access == 0 else "private"


def cmd_pages(args: argparse.Namespace) -> None:
    """`se pages <project>` — list pages in a Plane project as a table.

    Output columns: ID, NAME, ACCESS. Sorted by name for stable ordering.
    Public pages only by default; pass `--include-private` to widen.
    Use `--json` to emit a machine-readable array instead of the table.
    """
    _apply_plane_profile_env(args)

    project_id = args.project_id or args.project
    if not project_id:
        print(
            "ERROR: pass a project as a positional arg or via --project. "
            "Examples:\n  se pages CAPP\n  se pages --project CAPP",
            file=sys.stderr,
        )
        sys.exit(2)

    script = _repo_root() / "download_project_pages.py"
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        sys.exit(1)

    dpp = _load_module("download_project_pages", script)
    cfg = dpp.load_config()  # exits on its own with a clear message if creds missing

    try:
        project_uuid, project_code = dpp.resolve_project(cfg, project_id)
    except SystemExit as exc:
        print(exc, file=sys.stderr)
        sys.exit(1)

    try:
        all_pages = dpp.list_pages(cfg, project_uuid)
    except Exception as exc:
        print(f"ERROR listing pages: {exc}", file=sys.stderr)
        sys.exit(2)

    if args.include_private:
        pages = all_pages
        filter_note = "(public + private — --include-private)"
    else:
        pages = [p for p in all_pages if dpp.is_public_page(p)]
        hidden = len(all_pages) - len(pages)
        filter_note = (
            f"(public only; {hidden} private hidden — pass --include-private)"
            if hidden else "(public only)"
        )

    # Stable, predictable order: by name (case-insensitive), then id.
    pages = sorted(pages, key=lambda p: (str(p.get("name", "")).casefold(),
                                         str(p.get("id", ""))))

    if args.json:
        payload = [
            {
                "id": p.get("id"),
                "name": p.get("name"),
                "access": _se_pages_format_access(p),
            }
            for p in pages
        ]
        print(json.dumps(payload, indent=2))
        sys.exit(0)

    # Plain-text table. Column widths dynamic so long names don't wrap.
    rows = [
        (str(p.get("id", "")), str(p.get("name", "") or "<untitled>"),
         _se_pages_format_access(p))
        for p in pages
    ]
    headers = ("ID", "NAME", "ACCESS")
    widths = [
        max(len(headers[i]), max((len(r[i]) for r in rows), default=0))
        for i in range(3)
    ]

    print(f"Project: {project_code}  ({project_uuid})  workspace={cfg['workspace']}")
    print(f"Pages:   {len(pages)} of {len(all_pages)} total {filter_note}")
    print()
    sep = "  "
    fmt = sep.join(f"{{:<{w}}}" for w in widths)
    print(fmt.format(*headers))
    print(fmt.format(*("-" * w for w in widths)))
    for row in rows:
        print(fmt.format(*row))
    sys.exit(0)


def _resolve_plane_source(args: argparse.Namespace) -> tuple[str, str | None]:
    """When --plane-project + --plane-page are set, download the page
    and return `(local_markdown_path, project_code)`. Otherwise return
    `(args.source, None)`.

    The returned `project_code` is the Plane short identifier (e.g.
    "CAPP"); the caller may use it to default the drafts namespace
    (`args.project`) when the operator didn't pass `--project`.

    Validates flag combinations and exits with a clear message on
    misuse before invoking the generator pipeline.
    """
    has_plane = bool(args.plane_project) and bool(args.plane_page)
    has_any_plane = bool(args.plane_project) or bool(args.plane_page)
    if has_any_plane and not has_plane:
        print(
            "ERROR: --plane-project and --plane-page must be used together.",
            file=sys.stderr,
        )
        sys.exit(1)
    if args.source and has_plane:
        print(
            "ERROR: pass either a local source path OR "
            "--plane-project + --plane-page, not both.",
            file=sys.stderr,
        )
        sys.exit(1)
    if not args.source and not has_plane:
        print(
            "ERROR: need a source — pass a markdown path or "
            "--plane-project <code> --plane-page <uuid>.",
            file=sys.stderr,
        )
        sys.exit(1)
    if not has_plane:
        return args.source, None

    # Plane mode — fetch the single page via download_project_pages.
    script = _repo_root() / "download_project_pages.py"
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        sys.exit(1)
    dl = _load_module("download_project_pages", script)
    cfg = dl.load_config()
    project_uuid, project_code = dl.resolve_project(cfg, args.plane_project)
    out_path = dl.download_single_page(
        cfg, project_uuid, project_code, args.plane_page,
        output_root="systems",
    )
    return str(out_path), project_code


