_CLAUDE_COMMANDS = {
    "deploy": _DEPLOY_COMMAND_MD,
    "generate": _GENERATE_COMMAND_MD,
    "qa": _QA_COMMAND_MD,
}


def _install_claude_assets(
    base: Path,
    *,
    force: bool = False,
) -> tuple[list[str], list[str], list[str]]:
    """Materialise sub-agents + slash-commands under <base>/.claude/.

    Returns (created, skipped, missing_sources). `missing_sources` is non-empty
    only when the bundled `agents/<name>/AGENT.md` cannot be located — that
    indicates a broken bundle, not an operator error.
    """
    created: list[str] = []
    skipped: list[str] = []
    missing: list[str] = []

    src_root = _repo_root()
    agents_dir = base / ".claude" / "agents"
    commands_dir = base / ".claude" / "commands"

    # Sub-agents: copy AGENT.md → .claude/agents/<name>.md
    for name in _SUBAGENTS:
        src = src_root / "agents" / name / "AGENT.md"
        if not src.exists():
            missing.append(str(src))
            continue
        dst = agents_dir / f"{name}.md"
        if dst.exists() and not force:
            skipped.append(str(dst))
            continue
        dst.parent.mkdir(parents=True, exist_ok=True)
        dst.write_text(src.read_text())
        created.append(str(dst))

    # Slash-command stubs (inline templates — no external source)
    for name, content in _CLAUDE_COMMANDS.items():
        dst = commands_dir / f"{name}.md"
        if dst.exists() and not force:
            skipped.append(str(dst))
            continue
        dst.parent.mkdir(parents=True, exist_ok=True)
        dst.write_text(content)
        created.append(str(dst))

    return created, skipped, missing


# ── se init ───────────────────────────────────────────────────────────────────


def cmd_init(args: argparse.Namespace) -> None:
    base = Path(args.dir).resolve()
    created: list[str] = []
    skipped: list[str] = []

    def _scaffold_file(path: Path, content: str) -> None:
        if path.exists():
            skipped.append(str(path))
        else:
            path.parent.mkdir(parents=True, exist_ok=True)
            path.write_text(content)
            created.append(str(path))

    def _scaffold_dir(path: Path) -> None:
        if path.exists():
            skipped.append(str(path) + "/")
        else:
            path.mkdir(parents=True)
            created.append(str(path) + "/")

    _scaffold_file(base / "repos.yaml", _REPOS_YAML)
    _scaffold_file(base / "policies" / "default.yaml", _POLICIES_YAML)
    _scaffold_file(base / ".env.example", _ENV_EXAMPLE)
    _scaffold_file(base / "docs" / "env-setup.md", _ENV_SETUP_MD)
    _scaffold_dir(base / "logs")

    # Materialise Claude Code sub-agents + slash commands under .claude/
    # so an operator running `claude` in this dir sees /deploy, /generate,
    # /qa and the three sub-agents immediately.
    if not getattr(args, "no_claude_assets", False):
        ca_created, ca_skipped, ca_missing = _install_claude_assets(
            base, force=getattr(args, "force_claude_assets", False)
        )
        created.extend(ca_created)
        skipped.extend(ca_skipped)
        if ca_missing:
            print(
                "  warning  bundled AGENT.md sources not found "
                "(broken bundle?):"
            )
            for m in ca_missing:
                print(f"           {m}")

    for p in created:
        print(f"  created  {p}")
    for p in skipped:
        print(f"  exists   {p} (skipped)")

    if not created:
        print("Nothing to do — all artifacts already exist.")


# ── se repos ──────────────────────────────────────────────────────────────────
#
# Manages the fleet-runtime registry at <dir>/repos.yaml (keyed by repo NAME).
# Distinct from repo-map.yaml — see the file-level doc in repos.yaml itself
# and docs/stellar-engine/strategy.md §D4.
#
#   se repos              # bare → list (backward-compat alias for `se repos list`)
#   se repos list [...]   # tabular or --json output
#   se repos add NAME --path PATH [--max-concurrent N] [--priority-threshold ...]
#                         # writes the entry atomically (tmp + rename), runs
#                         # `grava init` in PATH unless --no-init, and (when
#                         # --plane-project-id is given) installs the plane-
#                         # sync hook shim under <path>/.grava/hooks/. Refuses
#                         # to overwrite an existing entry without --force.
#
# Hook layout written by `repos add --plane-project-id <UUID>`:
#
#   <path>/.grava/hooks/plane-sync.sh    # executable shim (chmod 0755)
#   <path>/.grava/hooks/plane-sync.env   # PLANE_PROJECT_ID, etc. (chmod 0600)
#
# The shim prefers `se plane-sync` on PATH (binary install) and falls back to
# `python3 $STELLAR_ENGINE_HOME/agents/.../grava_plane_sync.py` (source
# install). Target-repo grava agents invoke it as:
#
#   bash "$REPO_ROOT/.grava/hooks/plane-sync.sh" "$ISSUE_ID" || true
#
# The two-level subparser (repos → list|add) is wired so a bare `se repos`
# still works (subparsers.required = False; cmd_repos defaults to list).


def cmd_repos(args: argparse.Namespace) -> None:
    """Dispatcher for `se repos {list,add}`. Bare `se repos` → list."""
    sub_action = getattr(args, "repos_cmd", None) or "list"
    if sub_action == "add":
        return cmd_repos_add(args)
    return _cmd_repos_list(args)


def _cmd_repos_list(args: argparse.Namespace) -> None:
    # Defensive defaults: bare `se repos` has no --json/--dir from list subparser
    json_out = getattr(args, "json", False)
    dir_arg = getattr(args, "dir", ".")
    base = Path(dir_arg).resolve()
    repos = _load_repos(base)

    if json_out:
        print(json.dumps(repos, indent=2))
        return

    if not repos:
        print("No repos configured. Edit repos.yaml (run `se init` first).")
        return

    cols = ["NAME", "PATH", "MAX_CONCURRENT", "PRIORITY_THRESHOLD", "POLL_INTERVAL"]
    rows = [
        [
            name,
            str(cfg.get("path", "")),
            str(cfg.get("max_concurrent", "")),
            str(cfg.get("priority_threshold", "")),
            str(cfg.get("poll_interval", "")),
        ]
        for name, cfg in repos.items()
    ]

    widths = [
        max(len(col), max((len(row[i]) for row in rows), default=0))
        for i, col in enumerate(cols)
    ]
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(fmt.format(*cols))
    print("  ".join("-" * w for w in widths))
    for row in rows:
        print(fmt.format(*row))


_PLANE_SYNC_HOOK_SH = """\
#!/usr/bin/env bash
# Plane sync hook — auto-generated by `se repos add`.
#
# Called from grava coder / reviewer / pr-creator agent prompts after each
# `grava signal`. Non-fatal: returns 0 unless the shim itself errors.
#
# Replace any existing `python3 ${STELLAR_ENGINE_HOME}/.../grava_plane_sync.py`
# block in your agent definitions with:
#
#     bash "$REPO_ROOT/.grava/hooks/plane-sync.sh" "$ISSUE_ID" || true
#
# Edit plane-sync.env to change PLANE_PROJECT_ID / GRAVA_REPO / SYSTEM_YAML.

set -uo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"

# shellcheck disable=SC1091
[ -f "$HOOK_DIR/plane-sync.env" ] && source "$HOOK_DIR/plane-sync.env"

if [ -z "${PLANE_PROJECT_ID:-}" ]; then
    echo "plane-sync: PLANE_PROJECT_ID unset (see $HOOK_DIR/plane-sync.env)" >&2
    exit 0
fi

ISSUE_ID="${1:-}"
GRAVA_REPO_RESOLVED="${GRAVA_REPO:-$REPO_ROOT}"

# Prefer `se plane-sync` (binary install). Fall back to direct script invoke
# when STELLAR_ENGINE_HOME points at a source checkout.
if command -v se >/dev/null 2>&1; then
    se plane-sync ${ISSUE_ID:+"$ISSUE_ID"} \\
        --project-id "$PLANE_PROJECT_ID" \\
        --grava-repo "$GRAVA_REPO_RESOLVED" \\
        ${SYSTEM_YAML:+--system-yaml "$SYSTEM_YAML"} \\
        --direction push \\
        || true
elif [ -n "${STELLAR_ENGINE_HOME:-}" ] && \\
     [ -f "$STELLAR_ENGINE_HOME/agents/task-generator/cli/grava_plane_sync.py" ]; then
    python3 "$STELLAR_ENGINE_HOME/agents/task-generator/cli/grava_plane_sync.py" \\
        ${ISSUE_ID:+"$ISSUE_ID"} \\
        --project-id "$PLANE_PROJECT_ID" \\
        --grava-repo "$GRAVA_REPO_RESOLVED" \\
        ${SYSTEM_YAML:+--system-yaml "$SYSTEM_YAML"} \\
        || true
else
    echo "plane-sync: neither \\`se\\` on PATH nor \\$STELLAR_ENGINE_HOME set; skipping" >&2
fi
"""


def _render_plane_sync_env(plane_project_id: str,
                           grava_repo: str | None = None,
                           system_yaml: str | None = None) -> str:
    lines = [
        "# Auto-generated by `se repos add`. Edit values as needed.",
        "# Sourced by plane-sync.sh before invoking `se plane-sync` /",
        "# `grava_plane_sync.py`.",
        "",
        f'PLANE_PROJECT_ID="{plane_project_id}"',
        "",
        "# GRAVA_REPO defaults to the repo containing this hook. Override only",
        "# if the grava DB lives outside this checkout.",
    ]
    if grava_repo:
        lines.append(f'GRAVA_REPO="{grava_repo}"')
    else:
        lines.append("# GRAVA_REPO=/abs/path/to/grava/repo")
    lines += [
        "",
        "# Optional: per-system Plane state-name → group map.",
    ]
    if system_yaml:
        lines.append(f'SYSTEM_YAML="{system_yaml}"')
    else:
        lines.append("# SYSTEM_YAML=/abs/path/to/systems/<Name>/system.yaml")
    return "\n".join(lines) + "\n"


def _install_plane_sync_hook(repo_path: Path,
                             plane_project_id: str,
                             system_yaml: str | None,
                             force: bool) -> list[str]:
    """Write `.grava/hooks/plane-sync.{sh,env}` under repo_path.

    Returns a list of human-readable status lines (printed by caller).
    """
    hook_dir = repo_path / ".grava" / "hooks"
    hook_dir.mkdir(parents=True, exist_ok=True)
    status: list[str] = []

    sh_path = hook_dir / "plane-sync.sh"
    sh_existed = sh_path.exists()
    if sh_existed and not force:
        status.append(f"  exists   {sh_path} (use --force to overwrite)")
    else:
        sh_path.write_text(_PLANE_SYNC_HOOK_SH)
        sh_path.chmod(0o755)
        status.append(f"  {'updated' if sh_existed else 'created'}  {sh_path}")

    env_path = hook_dir / "plane-sync.env"
    env_existed = env_path.exists()
    if env_existed and not force:
        status.append(f"  exists   {env_path} (use --force to overwrite)")
    else:
        env_path.write_text(
            _render_plane_sync_env(plane_project_id, None, system_yaml)
        )
        env_path.chmod(0o600)
        status.append(f"  {'updated' if env_existed else 'created'}  {env_path}")

    return status


def cmd_repos_add(args: argparse.Namespace) -> None:
    """Register a new repo in repos.yaml, running `grava init` if needed."""
    base = Path(args.dir).resolve()
    repos = _load_repos(base)

    if not args.name:
        args.name = Path(args.path).expanduser().resolve().name

    existed = args.name in repos
    if existed and not args.force:
        print(
            f"ERROR: repo '{args.name}' already in repos.yaml. "
            f"Use --force to overwrite.",
            file=sys.stderr,
        )
        sys.exit(1)

    repo_path = Path(args.path).expanduser().resolve()
    if not repo_path.exists():
        print(
            f"ERROR: path {repo_path} does not exist. "
            f"Create the directory (or clone the repo) first.",
            file=sys.stderr,
        )
        sys.exit(1)
    if not repo_path.is_dir():
        print(f"ERROR: {repo_path} is not a directory.", file=sys.stderr)
        sys.exit(1)

    # grava init (skipped if .grava/ already present, or --no-init given)
    grava_marker = repo_path / ".grava"
    if grava_marker.exists():
        print(f"  exists   {grava_marker}/ (skipping grava init)")
    elif args.no_init:
        print("  skipped  grava init (--no-init)")
    else:
        if not shutil.which("grava"):
