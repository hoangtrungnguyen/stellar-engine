#!/usr/bin/env python3
"""se — Stellar Engine operator CLI (Phase B: read-only commands).

Subcommands:
  init         Scaffold repos.yaml, policies/default.yaml, logs/
  repos        List or modify configured repos
    repos list  List entries (default action)
    repos add   Register a new repo (and `grava init` it if needed)
  doctor       Validate global tools and configured repos
  download     Pull Plane project pages to systems/<workspace>/<project>/
  generate     Run the generator chain (extract → outline → render)
  plane-sync   Sync a Grava issue → Plane (status / assignee / comments)
"""
from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path

try:
    import yaml
except ImportError:
    print("ERROR: pyyaml not installed. Run: pip install pyyaml>=6.0", file=sys.stderr)
    sys.exit(1)


# ── version (overwritten by scripts/build.sh at build time) ───────────────────
def _load_version() -> tuple[str, str, str]:
    """Load (__version__, __commit__, __build_date__) from cli/_version.py.

    Falls back gracefully if the file is absent.
    """
    import importlib.util
    here = Path(__file__).resolve().parent
    vfile = here / "_version.py"
    if not vfile.exists():
        meipass = getattr(sys, "_MEIPASS", None)
        if meipass:
            vfile = Path(meipass) / "cli" / "_version.py"
    if not vfile.exists():
        return ("0.0.0-dev", "unknown", "unknown")
    spec = importlib.util.spec_from_file_location("_version", vfile)
    if spec is None or spec.loader is None:
        return ("0.0.0-dev", "unknown", "unknown")
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return (
        getattr(mod, "__version__", "0.0.0-dev"),
        getattr(mod, "__commit__", "unknown"),
        getattr(mod, "__build_date__", "unknown"),
    )


SE_VERSION, SE_COMMIT, SE_BUILD_DATE = _load_version()


# ── data types ────────────────────────────────────────────────────────────────


@dataclass
class Check:
    name: str
    status: str  # "ok" | "warn" | "error"
    detail: str = ""


# ── repos.yaml I/O ────────────────────────────────────────────────────────────


def _load_repos(base: Path) -> dict[str, dict]:
    path = base / "repos.yaml"
    if not path.exists():
        return {}
    data = yaml.safe_load(path.read_text()) or {}
    return data.get("repos") or {}


# ── templates ─────────────────────────────────────────────────────────────────


_REPOS_YAML_HEADER = """\
# repos.yaml — fleet runtime registry (keyed by repo name)
# Distinct from repo-map.yaml (Plane UUID → repo, used by task-generator).
# See: docs/stellar-engine/strategy.md §D4

"""


_REPOS_YAML = _REPOS_YAML_HEADER + """\
repos: {}
# Example:
#   grava:
#     path: /path/to/grava
#     max_concurrent: 2
#     priority_threshold: medium   # low | medium | high
#     poll_interval: 60            # seconds between ready-backlog probes
"""


def _save_repos(base: Path, repos: dict[str, dict]) -> None:
    """Atomic write of repos.yaml; preserves header, drops Example block."""
    base.mkdir(parents=True, exist_ok=True)
    path = base / "repos.yaml"
    body = yaml.safe_dump(
        {"repos": repos or {}},
        sort_keys=False,
        default_flow_style=False,
    )
    tmp = path.with_suffix(".yaml.tmp")
    tmp.write_text(_REPOS_YAML_HEADER + body)
    tmp.replace(path)

_POLICIES_YAML = """\
# policies/default.yaml — global fleet policies
# Per-repo overrides: policies/<repo-name>.yaml

global_max_concurrent: 4
ship_timeout_minutes: 60
pause_on_failure_streak: 3

heartbeat:
  stale_threshold_minutes: 10
  check_interval_seconds: 30
"""


# ── se init ───────────────────────────────────────────────────────────────────


def cmd_init(args: argparse.Namespace) -> None:
    base = Path(args.dir).resolve()
    created: list[str] = []
    skipped: list[str] = []

    def _scaffold_file(path: Path, content: str) -> None:
        if path.exists():
            skipped.append(str(path))
        else:
            path.parent.mkdir(parents=True, exist_ok=True)
            path.write_text(content)
            created.append(str(path))

    def _scaffold_dir(path: Path) -> None:
        if path.exists():
            skipped.append(str(path) + "/")
        else:
            path.mkdir(parents=True)
            created.append(str(path) + "/")

    _scaffold_file(base / "repos.yaml", _REPOS_YAML)
    _scaffold_file(base / "policies" / "default.yaml", _POLICIES_YAML)
    _scaffold_dir(base / "logs")

    for p in created:
        print(f"  created  {p}")
    for p in skipped:
        print(f"  exists   {p} (skipped)")

    if not created:
        print("Nothing to do — all artifacts already exist.")


# ── se repos ──────────────────────────────────────────────────────────────────


def cmd_repos(args: argparse.Namespace) -> None:
    """Dispatcher for `se repos {list,add}`. Bare `se repos` → list."""
    sub_action = getattr(args, "repos_cmd", None) or "list"
    if sub_action == "add":
        return cmd_repos_add(args)
    return _cmd_repos_list(args)


def _cmd_repos_list(args: argparse.Namespace) -> None:
    # Defensive defaults: bare `se repos` has no --json/--dir from list subparser
    json_out = getattr(args, "json", False)
    dir_arg = getattr(args, "dir", ".")
    base = Path(dir_arg).resolve()
    repos = _load_repos(base)

    if json_out:
        print(json.dumps(repos, indent=2))
        return

    if not repos:
        print("No repos configured. Edit repos.yaml (run `se init` first).")
        return

    cols = ["NAME", "PATH", "MAX_CONCURRENT", "PRIORITY_THRESHOLD", "POLL_INTERVAL"]
    rows = [
        [
            name,
            str(cfg.get("path", "")),
            str(cfg.get("max_concurrent", "")),
            str(cfg.get("priority_threshold", "")),
            str(cfg.get("poll_interval", "")),
        ]
        for name, cfg in repos.items()
    ]

    widths = [
        max(len(col), max((len(row[i]) for row in rows), default=0))
        for i, col in enumerate(cols)
    ]
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(fmt.format(*cols))
    print("  ".join("-" * w for w in widths))
    for row in rows:
        print(fmt.format(*row))


def cmd_repos_add(args: argparse.Namespace) -> None:
    """Register a new repo in repos.yaml, running `grava init` if needed."""
    base = Path(args.dir).resolve()
    repos = _load_repos(base)

    existed = args.name in repos
    if existed and not args.force:
        print(
            f"ERROR: repo '{args.name}' already in repos.yaml. "
            f"Use --force to overwrite.",
            file=sys.stderr,
        )
        sys.exit(1)

    repo_path = Path(args.path).expanduser().resolve()
    if not repo_path.exists():
        print(
            f"ERROR: path {repo_path} does not exist. "
            f"Create the directory (or clone the repo) first.",
            file=sys.stderr,
        )
        sys.exit(1)
    if not repo_path.is_dir():
        print(f"ERROR: {repo_path} is not a directory.", file=sys.stderr)
        sys.exit(1)

    # grava init (skipped if .grava/ already present, or --no-init given)
    grava_marker = repo_path / ".grava"
    if grava_marker.exists():
        print(f"  exists   {grava_marker}/ (skipping grava init)")
    elif args.no_init:
        print("  skipped  grava init (--no-init)")
    else:
        if not shutil.which("grava"):
            print(
                "ERROR: grava binary not found in PATH. "
                "Install grava or re-run with --no-init.",
                file=sys.stderr,
            )
            sys.exit(1)
        print(f"  running  grava init in {repo_path}")
        r = subprocess.run(
            ["grava", "init"],
            cwd=str(repo_path),
            capture_output=True,
            text=True,
            timeout=120,
        )
        if r.returncode != 0:
            print(
                f"ERROR: grava init failed (exit {r.returncode}):\n"
                f"{r.stderr or r.stdout}",
                file=sys.stderr,
            )
            sys.exit(1)
        print(f"  created  {grava_marker}/")

    repos[args.name] = {
        "path": str(repo_path),
        "max_concurrent": args.max_concurrent,
        "priority_threshold": args.priority_threshold,
        "poll_interval": args.poll_interval,
    }
    _save_repos(base, repos)

    verb = "updated" if existed else "added  "
    print(f"  {verb}  repos.yaml: {args.name} → {repo_path}")


# ── se doctor ─────────────────────────────────────────────────────────────────


def _check_tool(name: str) -> Check:
    path = shutil.which(name)
    if not path:
        return Check(name, "error", f"'{name}' not found in PATH")
    try:
        r = subprocess.run([name, "--version"], capture_output=True, text=True, timeout=5)
        version_line = r.stdout.splitlines()[0][:80] if r.returncode == 0 and r.stdout else ""
        detail = path + (f" — {version_line}" if version_line else "")
        return Check(name, "ok", detail)
    except Exception as exc:
        return Check(name, "ok", f"{path} (version check error: {exc})")


def _check_repo(name: str, cfg: dict, base: Path) -> list[Check]:
    checks: list[Check] = []
    raw_path = cfg.get("path", "")
    repo = Path(raw_path) if os.path.isabs(str(raw_path)) else base / raw_path

    if not repo.exists():
        checks.append(Check(f"{name}: path", "error", f"{repo} does not exist"))
        return checks
    checks.append(Check(f"{name}: path", "ok", str(repo)))

    if (repo / ".grava").exists():
        checks.append(Check(f"{name}: .grava", "ok", ""))
    else:
        checks.append(Check(f"{name}: .grava", "error", f"{repo}/.grava not found"))

    ship_skill = repo / ".claude" / "skills" / "ship"
    if ship_skill.exists():
        checks.append(Check(f"{name}: /ship skill", "ok", ""))
    else:
        checks.append(Check(f"{name}: /ship skill", "warn",
                            f"{ship_skill} not found (needed for epic-task team)"))

    try:
        r = subprocess.run(
            ["grava", "doctor"], capture_output=True, text=True,
            cwd=str(repo), timeout=10,
        )
        if r.returncode == 0:
            checks.append(Check(f"{name}: grava doctor", "ok", ""))
        else:
            first_line = (r.stdout or r.stderr or "non-zero exit").splitlines()[0][:120]
            checks.append(Check(f"{name}: grava doctor", "error", first_line))
    except FileNotFoundError:
        checks.append(Check(f"{name}: grava doctor", "error", "grava binary not found"))
    except subprocess.TimeoutExpired:
        checks.append(Check(f"{name}: grava doctor", "warn", "timed out after 10s"))

    return checks


def _check_cron() -> Check:
    try:
        r = subprocess.run(["crontab", "-l"], capture_output=True, text=True, timeout=5)
        if "pr_merge_watcher" in r.stdout:
            return Check("cron: pr_merge_watcher", "ok", "installed")
    except Exception:
        return Check("cron: pr_merge_watcher", "warn", "cannot read crontab")
    return Check(
        "cron: pr_merge_watcher", "warn",
        "not installed — see CLAUDE.md §PR merge watcher for cron snippet",
    )


# ── generator checks (Phase G) ────────────────────────────────────────────────


def _check_python_module(module: str, *, required: bool = True,
                         note: str = "") -> Check:
    """Probe importability of a Python module. `required=False` downgrades a
    missing module to warn (deferred-dep info, not a hard error)."""
    import importlib.util
    spec = importlib.util.find_spec(module)
    if spec is not None:
        return Check(f"python: {module}", "ok", spec.origin or "")
    status = "error" if required else "warn"
    detail = f"not installed{(' — ' + note) if note else ''}"
    return Check(f"python: {module}", status, detail)


def _check_env_file(base: Path) -> Check:
    env_file = base / ".env"
    if env_file.exists():
        return Check(".env", "ok", str(env_file))
    example = base / ".env.example"
    hint = f"copy {example} → .env and edit" if example.exists() else "create from .env.example"
    return Check(".env", "warn", f"not present — {hint}")


def _check_generator(base: Path) -> list[Check]:
    """Generator agent: package importable, deps, drafts/ informational."""
    checks: list[Check] = []

    pkg_dir = base / "agents" / "generator"
    if not pkg_dir.exists():
        checks.append(Check("generator: package", "error",
                            f"{pkg_dir} not found"))
        return checks
    checks.append(Check("generator: package", "ok", str(pkg_dir)))

    # Phase A–E ships pure stdlib; markdownify is used by sibling tools.
    checks.append(_check_python_module("markdown", required=True))
    checks.append(_check_python_module("markdownify", required=True))

    # Deferred phases — info only.
    checks.append(_check_python_module(
        "anthropic", required=False,
        note="Phase D (LLM outline) deferred; manual via Claude Code today",
    ))
    checks.append(_check_python_module(
        "pymupdf", required=False,
        note="PDF frontend deferred; markdown source only",
    ))

    drafts = base / "drafts"
    if drafts.exists():
        try:
            n_runs = sum(
                1 for proj in drafts.iterdir() if (proj / "runs").is_dir()
                for _ in (proj / "runs").iterdir()
            )
            checks.append(Check("generator: drafts/",
                                "ok", f"{drafts} ({n_runs} run(s) on disk)"))
        except OSError as exc:
            checks.append(Check("generator: drafts/", "warn", str(exc)))
    else:
        checks.append(Check(
            "generator: drafts/", "warn",
            f"{drafts} not present — created on first `se generate` run",
        ))

    return checks


def _render(checks: list[Check]) -> int:
    icons = {"ok": "✓", "warn": "⚠", "error": "✗"}
    errors = warnings = 0
    for c in checks:
        detail = f"  {c.detail}" if c.detail else ""
        print(f"  {icons.get(c.status, '?')} {c.name}{detail}")
        if c.status == "error":
            errors += 1
        elif c.status == "warn":
            warnings += 1
    return 1 if errors else (2 if warnings else 0)


def cmd_doctor(args: argparse.Namespace) -> None:
    base = Path(args.dir).resolve()
    checks: list[Check] = []

    for tool in ("tmux", "grava", "gh", "claude"):
        checks.append(_check_tool(tool))

    repos = _load_repos(base)
    if not repos:
        checks.append(Check(
            "repos.yaml", "warn",
            "no repos configured — run `se init` then add entries to repos.yaml",
        ))
    else:
        for name, cfg in repos.items():
            checks.extend(_check_repo(name, cfg, base))

    checks.append(_check_cron())
    checks.append(_check_env_file(base))
    checks.extend(_check_generator(base))

    if args.json:
        print(json.dumps(
            [{"name": c.name, "status": c.status, "detail": c.detail} for c in checks],
            indent=2,
        ))
        rc = 1 if any(c.status == "error" for c in checks) else (
            2 if any(c.status == "warn" for c in checks) else 0
        )
        sys.exit(rc)

    rc = _render(checks)
    sys.exit(rc)


# ── se download ───────────────────────────────────────────────────────────────


def _repo_root() -> Path:
    """Locate the bundled repo root.

    In dev: cli/se sits next to download_project_pages.py and agents/.
    In a PyInstaller --onefile bundle: data files are extracted to
    sys._MEIPASS; everything is bundled flat under that root.
    """
    meipass = getattr(sys, "_MEIPASS", None)
    if meipass:
        return Path(meipass)
    return Path(__file__).resolve().parent.parent


def _load_module(name: str, file_path: Path):
    """Load a Python file as a module without requiring package structure."""
    import importlib.util
    spec = importlib.util.spec_from_file_location(name, file_path)
    if spec is None or spec.loader is None:
        raise ImportError(f"cannot load {file_path}")
    module = importlib.util.module_from_spec(spec)
    sys.modules[name] = module
    spec.loader.exec_module(module)
    return module


def cmd_download(args: argparse.Namespace) -> None:
    """Invoke download_project_pages.main directly."""
    script = _repo_root() / "download_project_pages.py"
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        sys.exit(1)

    mod = _load_module("download_project_pages", script)
    argv = [args.project_id, "--output-root", args.output_root]
    if args.dry_run:
        argv.append("--dry-run")
    sys.exit(mod.main(argv))


# ── se generate ───────────────────────────────────────────────────────────────


def cmd_generate(args: argparse.Namespace) -> None:
    """Invoke agents/generator/cli/run.main directly."""
    agents_dir = _repo_root() / "agents"
    script = agents_dir / "generator" / "cli" / "run.py"
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        sys.exit(1)

    # generator/cli/run.py expects `agents/` on sys.path so its lazy
    # `from generator.cli import …` imports resolve.
    if str(agents_dir) not in sys.path:
        sys.path.insert(0, str(agents_dir))

    mod = _load_module("generator_run", script)
    argv = [args.source, "--project", args.project]
    if args.drafts_root:
        argv += ["--drafts-root", args.drafts_root]
    if args.system_name:
        argv += ["--system-name", args.system_name]
    if args.run_id:
        argv += ["--run-id", args.run_id]
    if args.llm:
        argv.append("--llm")
    if args.no_llm:
        argv.append("--no-llm")
    if args.dry_run:
        argv.append("--dry-run")
    if args.step:
        argv += ["--step", args.step]
    sys.exit(mod.main(argv))


# ── se plane-sync ─────────────────────────────────────────────────────────────


def cmd_plane_sync(args: argparse.Namespace) -> None:
    """Invoke agents/task-generator/cli/grava_plane_sync.main directly."""
    agents_dir = _repo_root() / "agents"
    script = agents_dir / "task-generator" / "cli" / "grava_plane_sync.py"
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        sys.exit(1)

    # grava_plane_sync.py performs its own sys.path.insert for
    # agents/task-generator/, so its `from plane_client import …` resolves.
    mod = _load_module("grava_plane_sync", script)

    argv: list[str] = []
    if args.issue_id:
        argv.append(args.issue_id)
    argv += ["--project-id", args.project_id, "--grava-repo", args.grava_repo]
    if args.state_file:
        argv += ["--state-file", args.state_file]
    if args.system_yaml:
        argv += ["--system-yaml", args.system_yaml]
    if args.log_failures:
        argv += ["--log-failures", args.log_failures]
    if args.log_level:
        argv += ["--log-level", args.log_level]

    sys.exit(mod.main(argv))


# ── entrypoint ────────────────────────────────────────────────────────────────


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="se",
        description="Stellar Engine operator CLI",
    )
    parser.add_argument(
        "-V", "--version",
        action="version",
        version=f"se {SE_VERSION} (commit {SE_COMMIT}, built {SE_BUILD_DATE})",
    )
    sub = parser.add_subparsers(dest="cmd", metavar="COMMAND")
    sub.required = True

    p_init = sub.add_parser("init", help="Scaffold repos.yaml, policies/default.yaml, logs/")
    p_init.add_argument("--dir", default=".", metavar="DIR",
                        help="Directory to scaffold into (default: cwd)")

    p_repos = sub.add_parser("repos", help="List or modify configured repos")
    repos_sub = p_repos.add_subparsers(dest="repos_cmd", metavar="ACTION")
    # Don't require — bare `se repos` defaults to list (backward compat).

    p_repos_list = repos_sub.add_parser("list", help="List configured repos")
    p_repos_list.add_argument("--json", action="store_true", help="JSON output")
    p_repos_list.add_argument("--dir", default=".", metavar="DIR")

    p_repos_add = repos_sub.add_parser(
        "add",
        help="Register a new repo (runs `grava init` in <path> if .grava/ missing)",
    )
    p_repos_add.add_argument("name", help="Logical repo name (registry key)")
    p_repos_add.add_argument("--path", required=True, metavar="PATH",
                             help="Path to the repo's working tree (absolute or ~-expandable)")
    p_repos_add.add_argument("--max-concurrent", type=int, default=2, metavar="N",
                             help="Concurrent ships allowed (default: 2)")
    p_repos_add.add_argument("--priority-threshold",
                             choices=("low", "medium", "high"), default="medium",
                             help="Minimum priority to pick up (default: medium)")
    p_repos_add.add_argument("--poll-interval", type=int, default=60, metavar="SECONDS",
                             help="Backlog probe interval (default: 60s)")
    p_repos_add.add_argument("--force", action="store_true",
                             help="Overwrite an existing entry with the same name")
    p_repos_add.add_argument("--no-init", action="store_true",
                             help="Skip `grava init` in the target dir")
    p_repos_add.add_argument("--dir", default=".", metavar="DIR",
                             help="Stellar-engine config dir (where repos.yaml lives)")

    p_doc = sub.add_parser("doctor", help="Validate global tools and configured repos")
    p_doc.add_argument("--json", action="store_true", help="JSON output")
    p_doc.add_argument("--dir", default=".", metavar="DIR")

    p_dl = sub.add_parser("download",
                          help="Download Plane project pages to systems/<workspace>/<project>/")
    p_dl.add_argument("project_id", help="Plane project UUID or shortcode")
    p_dl.add_argument("--output-root", default="systems", metavar="DIR",
                      help="Output root (default: systems/)")
    p_dl.add_argument("--dry-run", action="store_true", help="List without writing")

    p_gen = sub.add_parser("generate",
                           help="Run the generator chain (extract → outline → render)")
    p_gen.add_argument("source", help="Path to source document (markdown today)")
    p_gen.add_argument("--project", required=True,
                       help="Project / system name (drafts subdir)")
    p_gen.add_argument("--drafts-root", default=None, metavar="DIR",
                       help="Drafts root (default: drafts/)")
    p_gen.add_argument("--system-name", default=None,
                       help="System H1 (default: --project value)")
    p_gen.add_argument("--run-id", default=None,
                       help="Override run ID (default: UTC timestamp)")
    gen_mode = p_gen.add_mutually_exclusive_group()
    gen_mode.add_argument("--llm", action="store_true",
                          help="Call Anthropic API (Phase D, deferred)")
    gen_mode.add_argument("--no-llm", action="store_true",
                          help="Skip outline; produce extract.json only")
    gen_mode.add_argument("--dry-run", action="store_true",
                          help="Extract only, do not render")
    p_gen.add_argument("--step", choices=("extract", "outline", "render"),
                       default=None, help="Run a single step")

    p_sync = sub.add_parser(
        "plane-sync",
        help="Sync a Grava issue's status/assignee/comments to its linked Plane work item",
    )
    p_sync.add_argument("issue_id", nargs="?", default=None,
                        help="Grava issue id (e.g. grava-0305). Omit to scan all plane-linked issues.")
    p_sync.add_argument("--project-id", required=True, metavar="UUID",
                        help="Plane project UUID")
    p_sync.add_argument("--grava-repo", required=True, metavar="PATH",
                        help="Path to Grava repo root (must contain .grava/dolt/)")
    p_sync.add_argument("--state-file", default=None, metavar="PATH",
                        help="State file path (default: ~/.local/share/grava-plane-sync/<project_id>.json)")
    p_sync.add_argument("--system-yaml", default=None, metavar="PATH",
                        help="Path to system.yaml containing plane_state_map")
    p_sync.add_argument("--log-failures", default=None, metavar="PATH",
                        help="Append-only JSONL log of non-success gates")
    p_sync.add_argument("--log-level", default=None,
