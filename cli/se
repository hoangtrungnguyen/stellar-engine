def _install_claude_assets(
    base: Path,
    *,
    force: bool = False,
) -> tuple[list[str], list[str], list[str]]:
    """Materialise sub-agents + slash-commands under <base>/.claude/.

    Returns (created, skipped, missing_sources). `missing_sources` is non-empty
    only when the bundled `agents/<name>/AGENT.md` cannot be located — that
    indicates a broken bundle, not an operator error.
    """
    created: list[str] = []
    skipped: list[str] = []
    missing: list[str] = []

    src_root = _repo_root()
    agents_dir = base / ".claude" / "agents"
    commands_dir = base / ".claude" / "commands"

    # Sub-agents: copy AGENT.md → .claude/agents/<name>.md
    for name in _SUBAGENTS:
        src = src_root / "agents" / name / "AGENT.md"
        if not src.exists():
            missing.append(str(src))
            continue
        dst = agents_dir / f"{name}.md"
        if dst.exists() and not force:
            skipped.append(str(dst))
            continue
        dst.parent.mkdir(parents=True, exist_ok=True)
        dst.write_text(src.read_text())
        created.append(str(dst))

    # Slash-command stubs (inline templates — no external source)
    for name, content in _CLAUDE_COMMANDS.items():
        dst = commands_dir / f"{name}.md"
        if dst.exists() and not force:
            skipped.append(str(dst))
            continue
        dst.parent.mkdir(parents=True, exist_ok=True)
        dst.write_text(content)
        created.append(str(dst))

    return created, skipped, missing


# ── full agent-tree scaffold (operator-local copy of agents/<name>/) ─────────
#
# `se init` (default ON, opt-out with --no-agent-trees) materialises every
# bundled subagent's full source tree under <base>/agents/<name>/ so the
# operator can read, customise, or fork the agent without spelunking into
# the stellar-engine checkout or PyInstaller bundle.
#
# Source: <src_root>/agents/<name>/  (canonical bundle contents)
# Target: <base>/agents/<name>/      (operator's working copy)
#
# Excluded from the copy: __pycache__/, .pytest_cache/, .mypy_cache/, and
# *.pyc / *.pyo files — runtime caches that have no business being scaffolded.
#
# Idempotency is per-file. If a destination file already exists and
# --force-agent-trees was NOT passed, that single file is skipped; other
# new files in the tree still get written. Lets operators safely re-run
# `se init` after editing a doc — only un-touched files get refreshed.


_AGENT_TREE_EXCLUDE_DIRS = {"__pycache__", ".pytest_cache", ".mypy_cache"}
_AGENT_TREE_EXCLUDE_SUFFIXES = {".pyc", ".pyo"}


def _install_agent_trees(
    base: Path,
    *,
    force: bool = False,
) -> tuple[list[str], list[str], list[str]]:
    """Copy bundled `agents/<name>/` subtrees into `<base>/agents/<name>/`.

    Returns (created, skipped, missing_sources) with the same shape as
    `_install_claude_assets`. Each entry in `created` / `skipped` is a
    per-file path so the init summary stays granular.
    """
    created: list[str] = []
    skipped: list[str] = []
    missing: list[str] = []

    src_root = _repo_root()

    for name in _SUBAGENTS:
        src_dir = src_root / "agents" / name
        if not src_dir.exists():
            missing.append(str(src_dir))
            continue
        dst_dir = base / "agents" / name
        for src_file in src_dir.rglob("*"):
            if any(part in _AGENT_TREE_EXCLUDE_DIRS for part in src_file.parts):
                continue
            if src_file.suffix in _AGENT_TREE_EXCLUDE_SUFFIXES:
                continue
            if not src_file.is_file():
                continue
            rel = src_file.relative_to(src_dir)
            dst_file = dst_dir / rel
            if dst_file.exists() and not force:
                skipped.append(str(dst_file))
                continue
            dst_file.parent.mkdir(parents=True, exist_ok=True)
            dst_file.write_bytes(src_file.read_bytes())
            # Preserve executable bit (matters for shell hooks bundled
            # alongside Python source).
            if os.access(src_file, os.X_OK):
                dst_file.chmod(dst_file.stat().st_mode | 0o111)
            created.append(str(dst_file))

    return created, skipped, missing


# ── se init ───────────────────────────────────────────────────────────────────


def _scaffold_repos_yaml(
    base: Path,
    created: list[str],
    preserved: list[str],
) -> None:
    """Scaffold `<base>/repos.yaml` while ALWAYS preserving existing repo entries.

    Three cases:
      1. No file → write the fresh template (empty `repos: {}`). Reported
         as `created`.
      2. File exists with zero repo entries → leave untouched, reported
         as `preserved` (empty).
      3. File exists with N repo entries → leave untouched, reported as
         `preserved <path> (N repos kept)` so the operator sees the
         exact count and knows nothing was lost.

    HARD LIMIT — DO NOT BREAK:
      Operator-added repos in repos.yaml MUST survive every `se init`
      invocation, including any future `--force` flags. The fleet-runtime
      registry is the source of truth for what's registered; init is a
      scaffold, not a reset. If you need a "reset repos.yaml" command
      add it as a separate subcommand (e.g. `se repos clear`) so the
      destructive action is named explicitly.
    """
    path = base / "repos.yaml"
    if not path.exists():
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(_REPOS_YAML)
        created.append(str(path))
        return

    existing = _load_repos(base)
    if existing:
        preserved.append(f"{path} ({len(existing)} repos kept)")
    else:
        preserved.append(str(path))


def cmd_init(args: argparse.Namespace) -> None:
    base = Path(args.dir).resolve()
    created: list[str] = []
    skipped: list[str] = []
    preserved: list[str] = []

    def _scaffold_file(path: Path, content: str) -> None:
        if path.exists():
            skipped.append(str(path))
        else:
            path.parent.mkdir(parents=True, exist_ok=True)
            path.write_text(content)
            created.append(str(path))

    def _scaffold_dir(path: Path) -> None:
        if path.exists():
            skipped.append(str(path) + "/")
        else:
            path.mkdir(parents=True)
            created.append(str(path) + "/")

    # repos.yaml is special: it's the fleet runtime registry (operator-
    # populated via `se repos add`). `se init` must NEVER clobber an
    # existing repos.yaml. Use the dedicated helper so the preservation
    # is visible in the summary as `preserved <path> (N repos kept)`.
    # NB: even if future code adds a global --force flag, this helper
    # must keep the existing entries intact — see hard-limit comment
    # on _scaffold_repos_yaml.
    _scaffold_repos_yaml(base, created, preserved)

    _scaffold_file(base / "policies" / "default.yaml", _POLICIES_YAML)
    _scaffold_file(base / ".env.example", _ENV_EXAMPLE)
    _scaffold_file(base / "docs" / "env-setup.md", _ENV_SETUP_MD)
    _scaffold_dir(base / "logs")

    # Materialise Claude Code sub-agents + slash commands under .claude/
    # so an operator running `claude` in this dir sees /deploy, /generate,
    # /qa and the three sub-agents immediately.
    if not getattr(args, "no_claude_assets", False):
        ca_created, ca_skipped, ca_missing = _install_claude_assets(
            base, force=getattr(args, "force_claude_assets", False)
        )
        created.extend(ca_created)
        skipped.extend(ca_skipped)
        if ca_missing:
            print(
                "  warning  bundled AGENT.md sources not found "
                "(broken bundle?):"
            )
            for m in ca_missing:
                print(f"           {m}")

    # Materialise full agent source trees under <base>/agents/<name>/ so
    # the operator can read / customise / fork each agent without digging
    # into the stellar-engine checkout or PyInstaller bundle.
    if not getattr(args, "no_agent_trees", False):
        at_created, at_skipped, at_missing = _install_agent_trees(
            base, force=getattr(args, "force_agent_trees", False)
        )
        created.extend(at_created)
        skipped.extend(at_skipped)
        if at_missing:
            print(
                "  warning  bundled agent source trees not found "
                "(broken bundle?):"
            )
            for m in at_missing:
                print(f"           {m}")

    for p in created:
        print(f"  created    {p}")
    for p in preserved:
        print(f"  preserved  {p}")
    for p in skipped:
        print(f"  exists     {p} (skipped)")

    if not created:
        print("Nothing to do — all artifacts already exist.")


# ── se repos ──────────────────────────────────────────────────────────────────
#
# Manages the fleet-runtime registry at <dir>/repos.yaml (keyed by repo NAME).
# Distinct from repo-map.yaml — see the file-level doc in repos.yaml itself
# and docs/stellar-engine/strategy.md §D4.
#
#   se repos              # bare → list (backward-compat alias for `se repos list`)
#   se repos list [...]   # tabular or --json output
#   se repos add NAME --path PATH [--max-concurrent N] [--priority-threshold ...]
#                         # writes the entry atomically (tmp + rename), runs
#                         # `grava init` in PATH unless --no-init, and (when
#                         # --plane-project-id is given) installs the plane-
#                         # sync hook shim under <path>/.grava/hooks/. Refuses
#                         # to overwrite an existing entry without --force.
#
# Hook layout written by `repos add --plane-project-id <UUID>`:
#
#   <path>/.grava/hooks/plane-sync.sh    # executable shim (chmod 0755)
#   <path>/.grava/hooks/plane-sync.env   # PLANE_PROJECT_ID, etc. (chmod 0600)
#
# The shim prefers `se plane-sync` on PATH (binary install) and falls back to
# `python3 $STELLAR_ENGINE_HOME/agents/.../grava_plane_sync.py` (source
# install). Target-repo grava agents invoke it as:
#
#   bash "$REPO_ROOT/.grava/hooks/plane-sync.sh" "$ISSUE_ID" || true
#
# The two-level subparser (repos → list|add) is wired so a bare `se repos`
# still works (subparsers.required = False; cmd_repos defaults to list).


def cmd_repos(args: argparse.Namespace) -> None:
    """Dispatcher for `se repos {list,add}`. Bare `se repos` → list."""
    sub_action = getattr(args, "repos_cmd", None) or "list"
    if sub_action == "add":
        return cmd_repos_add(args)
    return _cmd_repos_list(args)


def _cmd_repos_list(args: argparse.Namespace) -> None:
    # Defensive defaults: bare `se repos` has no --json/--dir from list subparser
    json_out = getattr(args, "json", False)
    dir_arg = getattr(args, "dir", ".")
    base = Path(dir_arg).resolve()
    repos = _load_repos(base)

    if json_out:
        print(json.dumps(repos, indent=2))
        return

    if not repos:
        print("No repos configured. Edit repos.yaml (run `se init` first).")
        return

    cols = ["NAME", "PATH", "MAX_CONCURRENT", "PRIORITY_THRESHOLD", "POLL_INTERVAL"]
    rows = [
        [
            name,
            str(cfg.get("path", "")),
            str(cfg.get("max_concurrent", "")),
            str(cfg.get("priority_threshold", "")),
            str(cfg.get("poll_interval", "")),
        ]
        for name, cfg in repos.items()
    ]

    widths = [
        max(len(col), max((len(row[i]) for row in rows), default=0))
        for i, col in enumerate(cols)
    ]
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(fmt.format(*cols))
    print("  ".join("-" * w for w in widths))
    for row in rows:
        print(fmt.format(*row))


_PLANE_SYNC_HOOK_SH = """\
#!/usr/bin/env bash
# Plane sync hook — auto-generated by `se repos add`.
#
# Called from grava coder / reviewer / pr-creator agent prompts after each
# `grava signal`. Non-fatal: returns 0 unless the shim itself errors.
#
# Replace any existing `python3 ${STELLAR_ENGINE_HOME}/.../grava_plane_sync.py`
# block in your agent definitions with:
#
#     bash "$REPO_ROOT/.grava/hooks/plane-sync.sh" "$ISSUE_ID" || true
#
# Edit plane-sync.env to change PLANE_PROJECT_ID / GRAVA_REPO / SYSTEM_YAML.

set -uo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"

# shellcheck disable=SC1091
[ -f "$HOOK_DIR/plane-sync.env" ] && source "$HOOK_DIR/plane-sync.env"

if [ -z "${PLANE_PROJECT_ID:-}" ]; then
    echo "plane-sync: PLANE_PROJECT_ID unset (see $HOOK_DIR/plane-sync.env)" >&2
    exit 0
fi

ISSUE_ID="${1:-}"
GRAVA_REPO_RESOLVED="${GRAVA_REPO:-$REPO_ROOT}"

# Prefer `se plane-sync` (binary install). Fall back to direct script invoke
# when STELLAR_ENGINE_HOME points at a source checkout.
if command -v se >/dev/null 2>&1; then
    se plane-sync ${ISSUE_ID:+"$ISSUE_ID"} \\
        --project-id "$PLANE_PROJECT_ID" \\
        --grava-repo "$GRAVA_REPO_RESOLVED" \\
        ${SYSTEM_YAML:+--system-yaml "$SYSTEM_YAML"} \\
        --direction push \\
        || true
elif [ -n "${STELLAR_ENGINE_HOME:-}" ] && \\
     [ -f "$STELLAR_ENGINE_HOME/agents/task-generator/cli/grava_plane_sync.py" ]; then
    python3 "$STELLAR_ENGINE_HOME/agents/task-generator/cli/grava_plane_sync.py" \\
        ${ISSUE_ID:+"$ISSUE_ID"} \\
        --project-id "$PLANE_PROJECT_ID" \\
        --grava-repo "$GRAVA_REPO_RESOLVED" \\
        ${SYSTEM_YAML:+--system-yaml "$SYSTEM_YAML"} \\
        || true
else
    echo "plane-sync: neither \\`se\\` on PATH nor \\$STELLAR_ENGINE_HOME set; skipping" >&2
fi
"""


# ── grava agent-team install (used by `se repos add`) ────────────────────────
#
# Mirrors the manual `cp` block in grava's docs/guides/INSTALL_AGENT_TEAM.md
# (Path B.3): every target repo registered via `se repos add` gets the same
# 6 agents + 12 skills the grava team ships canonically, copied straight
# from a local grava clone.
#
# Lookup order for the grava source clone:
#   1. --grava-src PATH         (explicit flag on `se repos add`)
#   2. $GRAVA_SRC               (env var; matches the convention in the
#                                grava install docs)
#   3. <stellar-engine-parent>/grava   (sibling-dir auto-detect for the
#                                       typical ~/Space/{stellar-engine,grava}
#                                       layout)
# If none resolve, the install is skipped with a hint — never fatal.
#
# Overwrite policy is ALWAYS-OVERWRITE: every `se repos add` (re-)syncs the
# repo's `.claude/{agents,skills}/` to whatever the current grava clone has.
# Operators who want to preserve customisations should pass --no-grava-assets
# and copy by hand. Rationale: the agent team is a canonical contract owned
# by grava; per-repo customisation is the exception, not the default.

_GRAVA_AGENTS = (
    "bug-hunter",
    "coder",
    "golang-pro",
    "planner",
    "pr-creator",
    "reviewer",
)

_GRAVA_SKILLS = (
    "ship",
    "hunt",
    "plan",
    "grava-bug-hunt",
    "grava-claim",
    "grava-cli",
    "grava-code-review",
    "grava-complete-dev-story",
    "grava-dev-epic",
    "grava-dev-task",
    "grava-gen-issues",
    "grava-next-issue",
)


_GRAVA_INSTALL_URL = (
    "https://raw.githubusercontent.com/hoangtrungnguyen/grava/main/scripts/install.sh"
)


def _ensure_grava_binary(*, auto_install: bool = True) -> bool:
    """Make sure the `grava` CLI is on PATH; install it via curl if missing.

    On a fresh machine the operator may not have grava installed yet.
    `se repos add` is the bootstrap entry point — it needs `grava` to run
    `grava init` in the target repo. Instead of failing, fetch the binary
    via grava's official install script (same one documented in grava's README).

    Returns True if grava is available after this call, False if install
    was disabled or failed.
    """
    if shutil.which("grava") is not None:
        return True

    if not auto_install:
        return False

    if shutil.which("curl") is None or shutil.which("bash") is None:
        print(
            "ERROR: grava not on PATH and curl/bash unavailable for auto-install.\n"
            f"  Install manually: curl -sL {_GRAVA_INSTALL_URL} | bash",
            file=sys.stderr,
        )
        return False

    print(f"  installing grava (curl -sL {_GRAVA_INSTALL_URL} | bash)")
    try:
        # Use a pipeline so the install script's output streams to the
        # operator's terminal — they see the download/install progress.
        r = subprocess.run(
            f"curl -sL {_GRAVA_INSTALL_URL} | bash",
            shell=True, check=False,
        )
    except OSError as exc:
        print(f"  install failed: {exc}", file=sys.stderr)
        return False

    if r.returncode != 0:
        print(
            f"  install failed (exit {r.returncode}). Install manually:\n"
            f"  curl -sL {_GRAVA_INSTALL_URL} | bash",
            file=sys.stderr,
        )
        return False

    # grava's install.sh drops the binary in ~/.local/bin by default — that
    # might not be on PATH yet in this process. Re-probe with the standard
    # install location appended.
    if shutil.which("grava") is not None:
        return True
    local_bin = Path.home() / ".local" / "bin"
    if (local_bin / "grava").is_file():
        os.environ["PATH"] = f"{local_bin}{os.pathsep}{os.environ.get('PATH', '')}"
        if shutil.which("grava") is not None:
            print(f"  added {local_bin} to PATH for this process")
            return True

    print(
        "  grava installed but not on PATH yet. Add this to your shell rc:\n"
        f"    export PATH=\"$HOME/.local/bin:$PATH\"\n"
        "  then re-run `se repos add`.",
        file=sys.stderr,
    )
    return False


def _resolve_grava_src(explicit: str | None) -> tuple[Path | None, str]:
    """Resolve the grava source clone path.

    Returns (path, reason) where `reason` is a human-readable description
    of which lookup step won (for the operator-facing log line). `path`
    is None if nothing resolved.

    Lookup chain (first match wins):
      1. --grava-src PATH                  (explicit flag)
      2. $GRAVA_SRC                        (env var; matches grava install docs)
      3. <bundle>/vendored/grava           (PyInstaller binary: assets vendored
                                            at build time — no clone needed.
                                            scripts/vendor-grava-assets.sh
                                            populates this dir.)
      4. <stellar-engine>/../grava sibling (SOURCE runs only — `_repo_root()`
                                            points at /tmp/_MEIxxx for the
                                            PyInstaller binary, so sibling
                                            detect is meaningless there)
      5. Common operator clone locations:
           ~/Space/grava, ~/src/grava, ~/IdeaProjects/grava,
           ~/Projects/grava, ~/code/grava, ~/grava
                                            (probed for source AND binary
                                             installs as a fallback)
    """
    if explicit:
        p = Path(explicit).expanduser().resolve()
        return (p if p.is_dir() else None,
                f"--grava-src {p}" + ("" if p.is_dir() else " (missing)"))
    env = os.environ.get("GRAVA_SRC")
    if env:
        p = Path(env).expanduser().resolve()
        return (p if p.is_dir() else None,
                f"$GRAVA_SRC={p}" + ("" if p.is_dir() else " (missing)"))

    # Bundled assets — built into the PyInstaller binary or present in the
    # source tree after scripts/vendor-grava-assets.sh runs locally. This is
    # the path that makes `se repos add` work on a fresh machine with no
    # grava clone (the assets travel with the binary).
    bundled = _repo_root() / "vendored" / "grava"
    if (bundled / ".claude" / "agents").is_dir():
        return (bundled, f"bundled {bundled}")

    tried: list[str] = []

    # Sibling-dir auto-detect — ONLY for source runs. In the PyInstaller
    # binary `_repo_root()` returns `sys._MEIPASS` (e.g. /tmp/_MEI123456),
    # so its parent / "grava" resolves to `/tmp/grava` which is never
    # what the operator means.
    is_binary = getattr(sys, "_MEIPASS", None) is not None
    if not is_binary:
        se_root = Path(__file__).resolve().parent.parent
        sibling = (se_root.parent / "grava").resolve()
        if sibling.is_dir():
            return (sibling, f"sibling {sibling}")
        tried.append(f"sibling {sibling}")

    # Common operator-clone locations. Probed for both source and binary
    # installs so the binary user gets a working default without having
    # to set $GRAVA_SRC for the typical layout.
    home = Path.home()
    for candidate in (home / "Space" / "grava",
                      home / "src" / "grava",
                      home / "IdeaProjects" / "grava",  # JetBrains IDE default
                      home / "Projects" / "grava",
                      home / "code" / "grava",
                      home / "grava"):
        if candidate.is_dir():
            return (candidate.resolve(), f"common-path {candidate}")
        tried.append(str(candidate))

    tried_str = ", ".join(tried) if tried else "no candidates"
    return (None,
            f"no grava clone found (tried --grava-src, $GRAVA_SRC, "
            f"{tried_str})")


def _install_grava_assets(
    repo_path: Path,
    grava_src: Path,
) -> tuple[list[str], list[str]]:
    """Copy grava's `.claude/agents/*.md` + `.claude/skills/<name>/` into
    the target repo. Always overwrites — see policy note above.

    Returns (status_lines, missing_sources). `missing_sources` is non-empty
    only when an agent .md or skill directory listed in _GRAVA_AGENTS /
    _GRAVA_SKILLS is absent from the source clone (broken or out-of-date
    clone — operator action required).
    """
    status: list[str] = []
    missing: list[str] = []

    src_agents = grava_src / ".claude" / "agents"
    src_skills = grava_src / ".claude" / "skills"
    dst_agents = repo_path / ".claude" / "agents"
    dst_skills = repo_path / ".claude" / "skills"
    dst_agents.mkdir(parents=True, exist_ok=True)
    dst_skills.mkdir(parents=True, exist_ok=True)

    for name in _GRAVA_AGENTS:
        src = src_agents / f"{name}.md"
        if not src.is_file():
            missing.append(str(src))
            continue
        dst = dst_agents / f"{name}.md"
        existed = dst.exists()
        shutil.copy2(src, dst)
        status.append(f"  {'updated' if existed else 'created'}  {dst}")

    for name in _GRAVA_SKILLS:
        src = src_skills / name
        if not src.is_dir():
            missing.append(str(src))
            continue
        dst = dst_skills / name
        existed = dst.exists()
        # dirs_exist_ok=True overwrites individual files but leaves any
        # extra files the operator may have added in the dest dir alone.
        # For a clean "match source exactly" we'd rmtree first — but
        # operators sometimes drop README.md / notes in skill dirs, and
        # nuking those silently would be worse than letting them linger.
        shutil.copytree(src, dst, dirs_exist_ok=True)
        status.append(f"  {'updated' if existed else 'created'}  {dst}/")

    return status, missing


def _render_plane_sync_env(plane_project_id: str,
                           grava_repo: str | None = None,
                           system_yaml: str | None = None) -> str:
    lines = [
        "# Auto-generated by `se repos add`. Edit values as needed.",
        "# Sourced by plane-sync.sh before invoking `se plane-sync` /",
        "# `grava_plane_sync.py`.",
        "",
        f'PLANE_PROJECT_ID="{plane_project_id}"',
        "",
        "# GRAVA_REPO defaults to the repo containing this hook. Override only",
        "# if the grava DB lives outside this checkout.",
    ]
    if grava_repo:
        lines.append(f'GRAVA_REPO="{grava_repo}"')
    else:
        lines.append("# GRAVA_REPO=/abs/path/to/grava/repo")
    lines += [
        "",
        "# Optional: per-system Plane state-name → group map.",
    ]
    if system_yaml:
        lines.append(f'SYSTEM_YAML="{system_yaml}"')
    else:
        lines.append("# SYSTEM_YAML=/abs/path/to/systems/<Name>/system.yaml")
    return "\n".join(lines) + "\n"


def _install_plane_sync_hook(repo_path: Path,
                             plane_project_id: str,
                             system_yaml: str | None,
                             force: bool) -> list[str]:
    """Write `.grava/hooks/plane-sync.{sh,env}` under repo_path.

    Returns a list of human-readable status lines (printed by caller).
    """
    hook_dir = repo_path / ".grava" / "hooks"
    hook_dir.mkdir(parents=True, exist_ok=True)
    status: list[str] = []

    sh_path = hook_dir / "plane-sync.sh"
    sh_existed = sh_path.exists()
    if sh_existed and not force:
        status.append(f"  exists   {sh_path} (use --force to overwrite)")
    else:
        sh_path.write_text(_PLANE_SYNC_HOOK_SH)
        sh_path.chmod(0o755)
        status.append(f"  {'updated' if sh_existed else 'created'}  {sh_path}")

    env_path = hook_dir / "plane-sync.env"
    env_existed = env_path.exists()
    if env_existed and not force:
        status.append(f"  exists   {env_path} (use --force to overwrite)")
    else:
        env_path.write_text(
            _render_plane_sync_env(plane_project_id, None, system_yaml)
        )
        env_path.chmod(0o600)
        status.append(f"  {'updated' if env_existed else 'created'}  {env_path}")

    return status


def cmd_repos_add(args: argparse.Namespace) -> None:
    """Register a new repo in repos.yaml, running `grava init` if needed."""
    base = Path(args.dir).resolve()
    repos = _load_repos(base)

    if not args.name:
        args.name = Path(args.path).expanduser().resolve().name

    existed = args.name in repos
    if existed and not args.force:
        print(
            f"ERROR: repo '{args.name}' already in repos.yaml. "
            f"Use --force to overwrite.",
            file=sys.stderr,
        )
        sys.exit(1)

    repo_path = Path(args.path).expanduser().resolve()
    if not repo_path.exists():
        print(
            f"ERROR: path {repo_path} does not exist. "
            f"Create the directory (or clone the repo) first.",
            file=sys.stderr,
        )
        sys.exit(1)
    if not repo_path.is_dir():
        print(f"ERROR: {repo_path} is not a directory.", file=sys.stderr)
        sys.exit(1)

    # Ensure the grava CLI is available — auto-install on a fresh machine.
    # Skip when --no-init is given (operator already chose not to run grava).
    if not args.no_init:
        _ensure_grava_binary(auto_install=True)

    # grava init (skipped if .grava/ already present, or --no-init given)
    grava_marker = repo_path / ".grava"
    if grava_marker.exists():
        print(f"  exists   {grava_marker}/ (skipping grava init)")
    elif args.no_init:
        print("  skipped  grava init (--no-init)")
    else:
        if not shutil.which("grava"):
            print(
                "ERROR: grava binary not found in PATH. "
                "Install grava or re-run with --no-init.",
                file=sys.stderr,
            )
            sys.exit(1)
        print(f"  running  grava init in {repo_path}")
        r = subprocess.run(
            ["grava", "init"],
            cwd=str(repo_path),
            capture_output=True,
            text=True,
            timeout=120,
        )
        if r.returncode != 0:
            print(
                f"ERROR: grava init failed (exit {r.returncode}):\n"
                f"{r.stderr or r.stdout}",
                file=sys.stderr,
            )
            sys.exit(1)
        print(f"  created  {grava_marker}/")

    # ── grava agent-team (.claude/agents + .claude/skills) ────────────────
    # Mirrors Path B.3 of grava's INSTALL_AGENT_TEAM.md. Default ON; skip
    # with --no-grava-assets. ALWAYS overwrites — operators keep canonical
    # files in sync with whatever the grava clone currently has.
    if args.no_grava_assets:
        print("  skipped  grava agents/skills (--no-grava-assets)")
    else:
        grava_src, reason = _resolve_grava_src(args.grava_src)
        if grava_src is None:
            print(f"  skipped  grava agents/skills ({reason})")
            print(
                "           pass --grava-src PATH or set $GRAVA_SRC, "
                "or use --no-grava-assets to silence."
            )
        else:
            print(f"  source   grava clone: {reason}")
            asset_status, asset_missing = _install_grava_assets(
                repo_path, grava_src
            )
            for line in asset_status:
                print(line)
            if asset_missing:
                print(
                    "  warning  grava clone is missing canonical assets "
                    "(stale clone? pull origin/main):"
                )
                for m in asset_missing:
                    print(f"           {m}")

    # ── Plane-sync hook (.grava/hooks/plane-sync.{sh,env}) ────────────────
    # Skip when the user explicitly opts out, or when no project id is given
    # (the hook needs PLANE_PROJECT_ID to function).
    hook_status: list[str] = []
    if args.no_hooks:
        print("  skipped  plane-sync hooks (--no-hooks)")
    elif not args.plane_project_id:
        print(
            "  skipped  plane-sync hooks (no --plane-project-id; "
            "re-run with it or write .grava/hooks/plane-sync.env by hand)"
        )
    else:
        hook_status = _install_plane_sync_hook(
            repo_path,
            plane_project_id=args.plane_project_id,
            system_yaml=args.system_yaml,
            force=args.force,
        )
        for line in hook_status:
            print(line)

    repos[args.name] = {
        "path": str(repo_path),
        "max_concurrent": args.max_concurrent,
        "priority_threshold": args.priority_threshold,
        "poll_interval": args.poll_interval,
    }
    if args.plane_project_id:
        repos[args.name]["plane_project_id"] = args.plane_project_id
    _save_repos(base, repos)

    verb = "updated" if existed else "added  "
    print(f"  {verb}  repos.yaml: {args.name} → {repo_path}")

    # ── scaffold systems/<name>/ ───────────────────────────────────────────────
    systems_dir = base / "systems" / args.name
    if systems_dir.exists() and not args.force:
        print(f"  exists   systems/{args.name}/ (skipping scaffold)")
    else:
        systems_dir.mkdir(parents=True, exist_ok=True)

        system_yaml = systems_dir / "system.yaml"
        if not system_yaml.exists() or args.force:
            plane_id = args.plane_project_id or "REPLACE_WITH_PLANE_PROJECT_UUID"
            system_yaml.write_text(
                f"# {args.name} system config for the task-generator agent.\n"
                f"#\n"
                f"# Fill in the Plane project UUID and git URL, then run:\n"
                f"#   se repos add --path {repo_path} --plane-project-id <UUID>\n"
                f"\n"
                f"projects:\n"
                f"  \"{plane_id}\":\n"
                f"    repo_name: {args.name}\n"
                f"    git_url: REPLACE_WITH_GIT_URL\n"
                f"    workspace_prefix: REPLACE_WITH_PREFIX\n"
                f"\n"
                f"plane_state_map:\n"
