def main() -> None:
    parser = argparse.ArgumentParser(
        prog="se",
        description="Stellar Engine operator CLI",
    )
    parser.add_argument(
        "-V", "--version",
        action="version",
        version=f"se {SE_VERSION} (commit {SE_COMMIT}, built {SE_BUILD_DATE})",
    )
    sub = parser.add_subparsers(dest="cmd", metavar="COMMAND")
    sub.required = True

    p_init = sub.add_parser(
        "init",
        help="Scaffold repos.yaml, policies/default.yaml, logs/, "
             ".env.example, docs/env-setup.md, .claude/agents/, "
             ".claude/commands/, agents/{generator,task-generator,orchestrator}/",
    )
    p_init.add_argument("--dir", default=".", metavar="DIR",
                        help="Directory to scaffold into (default: cwd)")
    p_init.add_argument("--no-claude-assets", action="store_true",
                        dest="no_claude_assets",
                        help="Skip installing .claude/agents/ and .claude/commands/")
    p_init.add_argument("--force-claude-assets", action="store_true",
                        dest="force_claude_assets",
                        help="Overwrite existing .claude/{agents,commands}/*.md")
    p_init.add_argument("--no-agent-trees", action="store_true",
                        dest="no_agent_trees",
                        help="Skip installing full agent source trees under "
                             "<dir>/agents/{generator,task-generator,orchestrator}/")
    p_init.add_argument("--force-agent-trees", action="store_true",
                        dest="force_agent_trees",
                        help="Overwrite existing files in <dir>/agents/<name>/")

    p_repos = sub.add_parser("repos", help="List or modify configured repos")
    repos_sub = p_repos.add_subparsers(dest="repos_cmd", metavar="ACTION")
    # Don't require — bare `se repos` defaults to list (backward compat).

    p_repos_list = repos_sub.add_parser("list", help="List configured repos")
    p_repos_list.add_argument("--json", action="store_true", help="JSON output")
    p_repos_list.add_argument("--dir", default=".", metavar="DIR")

    p_repos_add = repos_sub.add_parser(
        "add",
        help="Register a new repo (runs `grava init` + installs grava "
             "agents/skills into <path>/.claude/)",
    )
    p_repos_add.add_argument("name", nargs="?", default=None,
                             help="Logical repo name (registry key); defaults to the folder name of --path")
    p_repos_add.add_argument("--path", required=True, metavar="PATH",
                             help="Path to the repo's working tree (absolute or ~-expandable)")
    p_repos_add.add_argument("--max-concurrent", type=int, default=2, metavar="N",
                             help="Concurrent ships allowed (default: 2)")
    p_repos_add.add_argument("--priority-threshold",
                             choices=("low", "medium", "high"), default="medium",
                             help="Minimum priority to pick up (default: medium)")
    p_repos_add.add_argument("--poll-interval", type=int, default=60, metavar="SECONDS",
                             help="Backlog probe interval (default: 60s)")
    p_repos_add.add_argument("--force", action="store_true",
                             help="Overwrite an existing entry with the same name")
    p_repos_add.add_argument("--no-init", action="store_true",
                             help="Skip `grava init` in the target dir")
    p_repos_add.add_argument("--plane-project-id", default=None, metavar="UUID",
                             help="Plane project UUID. When set, writes "
                                  "<path>/.grava/hooks/plane-sync.{sh,env} so "
                                  "grava agents can sync status to Plane.")
    p_repos_add.add_argument("--system-yaml", default=None, metavar="PATH",
                             help="Absolute path to systems/<Name>/system.yaml "
                                  "(only used by the plane-sync hook)")
    p_repos_add.add_argument("--no-hooks", action="store_true",
                             help="Skip plane-sync hook installation even "
                                  "when --plane-project-id is given")
    p_repos_add.add_argument("--grava-src", default=None, metavar="PATH",
                             dest="grava_src",
                             help="Path to a local grava clone — used to "
                                  "source the canonical 6 agents + 12 skills "
                                  "for <path>/.claude/. Falls back to "
                                  "$GRAVA_SRC, then a sibling `../grava` dir "
                                  "next to the stellar-engine checkout.")
    p_repos_add.add_argument("--no-grava-assets", action="store_true",
                             dest="no_grava_assets",
                             help="Skip installing grava agents/skills into "
                                  "<path>/.claude/. Default behaviour copies "
                                  "the canonical set (always overwriting) so "
                                  "every registered repo runs the same agent "
                                  "team.")
    p_repos_add.add_argument("--dir", default=".", metavar="DIR",
                             help="Stellar-engine config dir (where repos.yaml lives)")

    p_doc = sub.add_parser("doctor", help="Validate global tools and configured repos")
    p_doc.add_argument("--json", action="store_true", help="JSON output")
    p_doc.add_argument("--dir", default=".", metavar="DIR")

    p_dl = sub.add_parser("download",
                          help="Download Plane project PUBLIC pages to "
                               "systems/<workspace>/<project>/ "
                               "(pass --include-private for everything)")
    p_dl.add_argument("project_id",
                      help="Plane project UUID or short identifier (e.g. CAPP)")
    p_dl.add_argument("--output-root", default="systems", metavar="DIR",
                      help="Output root (default: systems/)")
    # `--page-id` and `--page-name` are alternative ways to point at one
    # specific page. Mutually exclusive so the operator can't accidentally
    # pass both — pick the UUID path (precise) or the name path (friendly).
    page_target = p_dl.add_mutually_exclusive_group()
    page_target.add_argument("--page-id", default=None,
                             help="Download only this page UUID (skip listing the project)")
    page_target.add_argument("--page-name", default=None,
                             help="Download only the page with this exact "
                                  "(case-sensitive) name. Stops with exit 2 "
                                  "if multiple pages share the name; "
                                  "use --page-id then.")
    p_dl.add_argument("--dry-run", action="store_true", help="List without writing")
    p_dl.add_argument("--include-private", action="store_true",
                      dest="include_private",
                      help="Also download private (access=1) pages. "
                           "Default behaviour is public-pages-only.")

    # ── se pages ──────────────────────────────────────────────────────────
    # `se pages <project>` lists pages in a Plane project. Positional is
    # the primary path; `--project` is an alias for muscle-memory parity
    # with other commands. Either resolves to `args.project_id` /
    # `args.project` — cmd_pages picks whichever is set.
    p_pages = sub.add_parser(
        "pages",
        help="List pages in a Plane project as a table "
             "(public-only by default; --include-private for everything)",
    )
    p_pages.add_argument(
        "project_id", nargs="?", default=None,
        help="Plane project UUID or short identifier (e.g. CAPP). "
             "Equivalent to passing --project.",
    )
    p_pages.add_argument(
        "--project", default=None, metavar="ID",
        help="Alias for the positional argument; useful when chaining "
             "shell commands or matching the exact syntax in docs.",
    )
    p_pages.add_argument(
        "--include-private", action="store_true", dest="include_private",
        help="Also list private (access=1) pages. Default is public only.",
    )
    p_pages.add_argument(
        "--json", action="store_true",
        help="Emit a JSON array of {id, name, access} instead of the table.",
    )
    _add_plane_profile_flags(p_pages)

    p_gen = sub.add_parser("generate",
                           help="Run the generator chain (extract → outline → render)")
    p_gen.add_argument("source", nargs="?", default=None,
                       help="Path to source document (markdown). Omit when "
                            "using --plane-project + --plane-page.")
    p_gen.add_argument("--plane-project", default=None, dest="plane_project",
                       metavar="CODE_OR_UUID",
                       help="Pull source from Plane: project UUID or short "
                            "identifier (e.g. CAPP). Requires --plane-page.")
    p_gen.add_argument("--plane-page", default=None, dest="plane_page",
                       metavar="PAGE_UUID",
                       help="Plane page UUID to use as source. Pairs with "
                            "--plane-project; downloaded to "
                            "systems/<workspace>/<project>/<slug>.md.")
    p_gen.add_argument("--project", default=None,
                       help="Override the drafts namespace + system H1. "
                            "Defaults to the source filename stem in local "
                            "mode, or the Plane project code (e.g. CAPP) "
                            "in --plane-project mode.")
    p_gen.add_argument("--drafts-root", default=None, metavar="DIR",
                       help="Drafts root (default: drafts/)")
    p_gen.add_argument("--system-name", default=None,
                       help="System H1 (default: --project value)")
    p_gen.add_argument("--run-id", default=None,
                       help="Override run ID (default: UTC timestamp)")
    gen_mode = p_gen.add_mutually_exclusive_group()
    gen_mode.add_argument("--llm", action="store_true",
                          help="Call Anthropic API (Phase D, deferred)")
    gen_mode.add_argument("--no-llm", action="store_true",
                          help="Skip outline; produce extract.json only")
    gen_mode.add_argument("--dry-run", action="store_true",
                          help="Extract only, do not render")
    p_gen.add_argument("--step", choices=("extract", "outline", "render"),
                       default=None, help="Run a single step")

    p_tg = sub.add_parser(
        "taskgen",
        help="Plane spec page → Plane epics/stories/tasks + Grava mirror",
    )
    p_tg.add_argument("project_id", help="Plane project UUID")
    p_tg.add_argument("page_id", help="Plane page UUID (the spec page)")
    p_tg.add_argument("--target-repo", default=None, metavar="DIR",
                      help="Override repo-map.yaml lookup")
    p_tg.add_argument("--no-clone", action="store_true",
                      help="Fail instead of auto-cloning a missing target repo")
    p_tg.add_argument("--allow-duplicate-pages", action="store_true",
                      help="Proceed even if Plane has duplicate pages with the same title")
    p_tg.add_argument("--dry-run", action="store_true",
                      help="Preview the plan only — skip all writes")
    p_tg.add_argument("--no-grava", action="store_true",
                      help="Skip Phase 3 Grava mirror (Plane writes only)")
    p_tg.add_argument("--yes", action="store_true",
                      help="Skip interactive confirmation prompts")
    p_tg.add_argument("--on-failure", choices=("prompt", "rollback", "abort"),
                      default=None, help="Behaviour when a Plane op fails")
    p_tg.add_argument("--json-report", default=None, metavar="PATH",
                      help="Write a JSON run summary to this path")
    p_tg.add_argument("--run-id", default=None,
                      help="Override run ID (default: UTC timestamp)")
    p_tg.add_argument("--no-dep-reorder", action="store_true",
                      help="Detect deps but keep markdown order")
    p_tg.add_argument("--allow-dep-cycles", action="store_true",
                      help="Continue when a dep cycle is detected")
    p_tg.add_argument("--strict-deps", action="store_true",
                      help="Fail when a dep ref cannot be resolved")
    p_tg.add_argument("--no-plane-relations", action="store_true",
                      help="Skip posting Plane `blocking` relations")
    _add_plane_profile_flags(p_tg)

    p_sync = sub.add_parser(
        "plane-sync",
        help="Sync a Grava issue's status/assignee/comments to its linked Plane work item",
    )
    p_sync.add_argument("issue_id", nargs="?", default=None,
                        help="Grava issue id (e.g. grava-0305). Omit to scan all plane-linked issues.")
    p_sync.add_argument("--project-id", required=True, metavar="UUID",
                        help="Plane project UUID")
    p_sync.add_argument("--grava-repo", required=True, metavar="PATH",
                        help="Path to Grava repo root (must contain .grava/dolt/)")
    p_sync.add_argument("--state-file", default=None, metavar="PATH",
                        help="State file path (default: ~/.local/share/grava-plane-sync/<project_id>.json)")
    p_sync.add_argument("--system-yaml", default=None, metavar="PATH",
                        help="Path to system.yaml containing plane_state_map")
    p_sync.add_argument("--log-failures", default=None, metavar="PATH",
                        help="Append-only JSONL log of non-success gates")
    p_sync.add_argument("--log-level", default=None,
                        choices=("DEBUG", "INFO", "WARNING", "ERROR"),
                        help="Log verbosity (default: INFO)")
    p_sync.add_argument("--direction", default="pull",
                        choices=("push", "pull", "both"),
                        help=(
                            "Sync direction. pull (default): import Plane "
                            "work items as new grava issues. "
                            "push: grava → Plane (status / assignee / comments). "
                            "both: pull then push."
                        ))
    _add_plane_profile_flags(p_sync)

    # ── se orchestrator (alias: `se o`) ───────────────────────────────────────
    p_orch = sub.add_parser(
        "orchestrator",
        aliases=["o"],
        help="Route + dispatch grava issues to fix-bug / qa / task-generator teams"
             " (shorthand: `se o`)",
    )
    orch_sub = p_orch.add_subparsers(dest="orch_cmd", metavar="ACTION")
    orch_sub.required = True

    # se orchestrator route <id>
    p_orch_route = orch_sub.add_parser("route", help="Classify an issue's team")
    p_orch_route.add_argument("id", help="Grava issue ID")
    p_orch_route.add_argument("--target-repo", default=".", metavar="PATH")

    # NOTE: `se o pick` was removed. The picker logic still ships as
    # `agents/orchestrator/cli/pick_ready.py` and is invoked internally
    # by `cmd_orchestrator_deploy` (via `_orch_pick_ids`) for the `--all`
    # batch loop and the no-arg auto-pick path. Operators who need the
    # raw ready list can call the script directly:
    #   python3 agents/orchestrator/cli/pick_ready.py --team T --limit N
    #   grava ready --json --limit N

    # se orchestrator doctor
    p_orch_doc = orch_sub.add_parser(
        "doctor",
        help="Verify env for orchestrator sub-pipelines + grava→Plane sync",
    )
    p_orch_doc.add_argument("--target-repo", default=".", metavar="PATH")
    p_orch_doc.add_argument("--json", action="store_true")
    _add_plane_profile_flags(p_orch_doc)

    # NOTE: `se o expand` was removed. To dispatch a known epic into the
    # task-generator pipeline use `se o deploy <epic-id>` instead — it
    # routes the epic to the `task-generator` team which invokes the
    # underlying `task_gen_expand.py` script the same way `expand` did.

    # se orchestrator deploy [<id>] [--team T]
    p_orch_dep = orch_sub.add_parser(
        "deploy",
        help="Route + fire Phase 0 for an issue (auto-picks if <id> omitted; "
             "use --all to batch over an entire team)",
    )
    p_orch_dep.add_argument("id", nargs="?", default=None,
                            help="Grava issue ID. Omit to auto-pick.")
    p_orch_dep.add_argument(
        "--team", default=None,
        choices=("fix-bug", "epic-task", "qa", "task-generator"),
        help="Filter for auto-pick / required for --all. "
             "Ignored when <id> is given (route decides).",
    )
    p_orch_dep.add_argument(
        "--repo", required=True, metavar="NAME",
        help="Repo NAME from repos.yaml (run `se repos` to list). "
             "Required — deploy refuses to run against unregistered repos.",
    )
    p_orch_dep.add_argument(
        "--dir", default=".", metavar="PATH",
        help="Stellar-engine workspace dir containing repos.yaml (default: cwd).",
    )
    p_orch_dep.add_argument("--dry-run", action="store_true",
                            help="Route only — do not fire Phase 0")
    p_orch_dep.add_argument("--all", action="store_true",
                            help="Loop over every ready issue for --team T, "
                                 "firing Phase 0 for each. Requires --team. "
                                 "Default: continue on per-issue errors.")
    p_orch_dep.add_argument("--limit", type=int, default=None,
                            help="Max issues to pick when --all is set "
                                 "(default: 100). Ignored otherwise.")
    p_orch_dep.add_argument("--stop-on-error", action="store_true",
                            help="With --all: bail at the first per-issue "
                                 "failure instead of continuing.")
    p_orch_dep.add_argument(
        "--detach", action="store_true",
        help="Create the tmux session in the background — don't attach "
             "to it now. Default: open a NEW terminal window running "
             "`tmux attach`. Falls back to current shell if no GUI terminal "
             "is available (SSH / headless).",
    )
    _add_plane_profile_flags(p_orch_dep)

    # NOTE: `se o start` removed — superseded by `se o deploy --repo NAME`,
    # which always opens a tmux+claude session (same behaviour as start did).

    # se orchestrator run — long-running fleet daemon (D0 scaffold).
    # See docs/orchestrator/daemon-plan.md. Currently a stub: every call
    # prints a one-line message and exits 0. The flag set is committed
    # forward through D1–D6; D1 wires the tick loop without changing
    # the surface.
    p_orch_run = orch_sub.add_parser(
        "run",
        help="Run the fleet daemon (D0 scaffold — stub today)",
    )
    p_orch_run.add_argument("--once", action="store_true",
                            help="Run a single tick and exit (D1+). "
                                 "Currently a no-op (the stub exits "
                                 "after one line either way).")
    p_orch_run.add_argument("--repos", default=None, metavar="PATH",
                            help="repos.yaml path (D1+). Defaults to "
                                 "<cwd>/repos.yaml.")
    p_orch_run.add_argument("--policies", default=None, metavar="DIR",
                            help="policies/ dir (D1+). Defaults to "
                                 "<cwd>/policies.")
    p_orch_run.add_argument("--max-concurrent", type=int, default=None,
                            dest="max_concurrent", metavar="N",
                            help="Global cap on in-flight pipelines "
                                 "across all repos (D1+).")
    p_orch_run.add_argument("--log-level", default="INFO",
                            dest="log_level",
                            choices=("DEBUG", "INFO", "WARNING", "ERROR"),
                            help="Log level (default: INFO).")

    # se orchestrator pr-watch — one-shot PR-lifecycle pass
    # (D6 — replaces agents/orchestrator/scripts/pr_merge_watcher.sh).
    # Same logic runs inside `se orchestrator run` on the 300s ticker;
    # this CLI exists for ad-hoc runs + parity testing.
    p_orch_prw = orch_sub.add_parser(
        "pr-watch",
        help="One-shot PR-lifecycle tick (replaces pr_merge_watcher.sh)",
    )
    p_orch_prw.add_argument("--once", action="store_true",
                            help="Required today; future continuous mode "
                                 "uses `se orchestrator run`.")
    p_orch_prw.add_argument("--repo", default=None, metavar="PATH",
                            help="Scan exactly this repo (bypasses repos.yaml).")
    p_orch_prw.add_argument("--repos", default=None, metavar="PATH",
                            help="Path to repos.yaml. Defaults to <cwd>/repos.yaml.")
    p_orch_prw.add_argument("--log-level", default="INFO",
                            dest="log_level",
                            choices=("DEBUG", "INFO", "WARNING", "ERROR"),
                            help="Log level (default: INFO).")

    # se orchestrator epic-task {claim}
    p_orch_et = orch_sub.add_parser("epic-task", help="Epic-task pipeline phases")
    et_sub = p_orch_et.add_subparsers(dest="et_cmd", metavar="PHASE")
    et_sub.required = True

    p_et_claim = et_sub.add_parser(
        "claim", help="Phase 0: claim story/task + provision worktree + resolve tech plan"
    )
    p_et_claim.add_argument("id", help="Grava task/story/subtask issue ID")
    p_et_claim.add_argument("--target-repo", default=".", metavar="PATH")
    p_et_claim.add_argument("--actor", default=None)

    # se orchestrator fix-bug {claim,verify,pr}
    p_orch_fb = orch_sub.add_parser("fix-bug", help="Fix-bug pipeline phases")
    fb_sub = p_orch_fb.add_subparsers(dest="fb_cmd", metavar="PHASE")
    fb_sub.required = True

    p_fb_claim = fb_sub.add_parser("claim", help="Phase 0: claim bug + provision worktree")
    p_fb_claim.add_argument("id", help="Grava bug issue ID")
    p_fb_claim.add_argument("--target-repo", default=".", metavar="PATH")
    p_fb_claim.add_argument("--actor", default=None)

    p_fb_ver = fb_sub.add_parser("verify", help="Phase 2: self-verify (tests/lint/build)")
    p_fb_ver.add_argument("id", help="Grava bug issue ID")
    p_fb_ver.add_argument("--target-repo", default=".", metavar="PATH")
    p_fb_ver.add_argument("--skip-verify", action="store_true",
                          help="Force PASS verdict without running checks")
    p_fb_ver.add_argument("--actor", default=None)
    p_fb_ver.add_argument("--state-file", default=None, metavar="PATH")

    p_fb_pr = fb_sub.add_parser("pr", help="Phase 3: push branch + open PR")
    p_fb_pr.add_argument("id", help="Grava bug issue ID")
    p_fb_pr.add_argument("--target-repo", default=".", metavar="PATH")
    p_fb_pr.add_argument("--actor", default=None)
    p_fb_pr.add_argument("--title", default=None)
    p_fb_pr.add_argument("--draft", action="store_true")

    # se orchestrator qa {load,report}
    p_orch_qa = orch_sub.add_parser("qa", help="QA pipeline phases")
    qa_sub = p_orch_qa.add_subparsers(dest="qa_cmd", metavar="PHASE")
    qa_sub.required = True

    p_qa_load = qa_sub.add_parser("load", help="Phase 0: resolve + stage checklist")
    p_qa_load.add_argument("id", help="Grava issue ID")
    p_qa_load.add_argument("--target-repo", default=".", metavar="PATH")
    p_qa_load.add_argument("--checklist", default=None, metavar="PATH")
    p_qa_load.add_argument("--type", default=None,
                           choices=("cli", "api", "web", "mobile"))
    p_qa_load.add_argument("--out", default=None, metavar="PATH")

    p_qa_rep = qa_sub.add_parser("report", help="Phase 2: render + post QA report")
    p_qa_rep.add_argument("id", help="Grava issue ID")
    p_qa_rep.add_argument("--results-file", required=True, metavar="PATH")
    p_qa_rep.add_argument("--target-repo", default=".", metavar="PATH")
    p_qa_rep.add_argument("--actor", default=None)

    args = parser.parse_args()

    # Auto-load `<engine-root>/.env` for every subcommand except `init`.
    # `init` scaffolds `.env.example` on a fresh dir — the operator hasn't
    # filled in `.env` yet, and init itself needs no credentials. Skipping
    # it keeps init usable on a clean checkout.
    if args.cmd != "init":
        _load_dotenv_if_present()

    # Two-level dispatch for `orchestrator <sub>` (alias: `o`)
    if args.cmd in ("orchestrator", "o"):
        orch_table = {
            "route":  cmd_orchestrator_route,
            # NOTE: `pick` removed — call pick_ready.py / `grava ready` directly.
            "doctor": cmd_orchestrator_doctor,
            # NOTE: `expand` removed — use `deploy <epic-id>` instead.
            "deploy": cmd_orchestrator_deploy,
            "run":    cmd_orchestrator_run,
            "pr-watch": cmd_orchestrator_pr_watch,
        }
        if args.orch_cmd in orch_table:
            orch_table[args.orch_cmd](args)
            return
        if args.orch_cmd == "epic-task":
            {
                "claim": cmd_orchestrator_epic_task_claim,
            }[args.et_cmd](args)
            return
        if args.orch_cmd == "fix-bug":
            {
                "claim":  cmd_orchestrator_fix_bug_claim,
                "verify": cmd_orchestrator_fix_bug_verify,
                "pr":     cmd_orchestrator_fix_bug_pr,
            }[args.fb_cmd](args)
            return
        if args.orch_cmd == "qa":
            {
                "load":   cmd_orchestrator_qa_load,
                "report": cmd_orchestrator_qa_report,
            }[args.qa_cmd](args)
            return

    {
        "init": cmd_init,
        "repos": cmd_repos,
        "doctor": cmd_doctor,
        "download": cmd_download,
        "pages": cmd_pages,
        "generate": cmd_generate,
        "taskgen": cmd_taskgen,
        "plane-sync": cmd_plane_sync,
    }[args.cmd](args)


if __name__ == "__main__":
    main()
