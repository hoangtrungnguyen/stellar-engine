    # generator/cli/run.py expects `agents/` on sys.path so its lazy
    # `from generator.cli import …` imports resolve.
    if str(agents_dir) not in sys.path:
        sys.path.insert(0, str(agents_dir))

    # Resolve source — either a local markdown path or a Plane page that
    # we download into systems/<workspace>/<project>/<slug>.md first.
    source, project_code = _resolve_plane_source(args)

