def _save_repos(base: Path, repos: dict[str, dict]) -> None:
    """Atomic write of repos.yaml; preserves header, drops Example block."""
    base.mkdir(parents=True, exist_ok=True)
    path = base / "repos.yaml"
    body = yaml.safe_dump(
        {"repos": repos or {}},
        sort_keys=False,
        default_flow_style=False,
    )
    tmp = path.with_suffix(".yaml.tmp")
    tmp.write_text(_REPOS_YAML_HEADER + body)
    tmp.replace(path)

