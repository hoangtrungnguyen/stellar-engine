def cmd_orchestrator_deploy(args: argparse.Namespace) -> None:
    """Open a dedicated tmux + Claude Code session and send /deploy to it.

    `se o deploy` ALWAYS launches a tmux session — there is no CLI batch
    mode. The actual pick/route/dispatch happens inside Claude Code, which
    follows agents/orchestrator/AGENT.md (tech plan load → pick → claim →
    implement → ship).

    Session lifecycle:
      - Session name: stellar-deploy-<repo-name>
      - If session does NOT exist: create it rooted in the target repo,
        start `claude` inside it, then send the /deploy command.
      - If session DOES exist: send-keys the new /deploy command into it.
        Useful for queueing additional work into a running orchestrator.
      - --attach: exec `tmux attach` after creation/queueing.

    The /deploy command is composed from the operator's args:
      <id>        → /deploy <id>
      --team T    → /deploy --team T
      --all       → /deploy --all
      --dry-run   → /deploy --dry-run
    Flags compose: `--repo X --team T --all --dry-run` → `/deploy --team T
    --all --dry-run`.
    """
    import shutil as _shutil
    import time as _time

    _apply_plane_profile_env(args)

    # 1. Resolve the registered repo NAME → absolute path via repos.yaml.
    base = Path(args.dir).resolve()
    target_repo = str(_resolve_named_repo(args.repo, base))

    # 2. Validate operator argument combinations early.
    if args.all and args.id:
        print("ERROR: --all cannot be combined with <id>", file=sys.stderr)
        sys.exit(2)
    if args.all and not args.team:
        print("ERROR: --all requires --team T", file=sys.stderr)
        sys.exit(2)

    # 3. Require tmux + claude on PATH — there's no CLI fallback.
    if _shutil.which("tmux") is None:
        print(
            "ERROR: tmux is not installed.\n"
            "  macOS:  brew install tmux\n"
            "  Ubuntu: sudo apt install tmux",
            file=sys.stderr,
        )
        sys.exit(1)
    if _shutil.which("claude") is None:
        print(
            "ERROR: claude CLI not found in PATH.\n"
            "  Install: https://claude.ai/claude-code",
            file=sys.stderr,
        )
        sys.exit(1)

    # 4. Compose the /deploy command sent into the Claude session.
    slash_parts = ["/deploy"]
    if args.id:
        slash_parts.append(args.id)
    if args.team:
        slash_parts += ["--team", args.team]
    if args.all:
        slash_parts.append("--all")
    if args.limit:
        slash_parts += ["--limit", str(args.limit)]
    if args.dry_run:
        slash_parts.append("--dry-run")
    if getattr(args, "stop_on_error", False):
        slash_parts.append("--stop-on-error")
    slash_cmd = " ".join(slash_parts)

    session_name = f"stellar-deploy-{args.repo}"
    detach = getattr(args, "detach", False)
    # `--detach` opts out of auto-attach. Default: open a NEW terminal
    # window running `tmux attach`. If no GUI terminal is available
    # (over SSH, headless), fall back to taking over the current shell.
    attach = not detach
    inside_tmux = bool(os.environ.get("TMUX"))

    def _open_new_window(attach_cmd: str) -> bool:
        """Try to open `attach_cmd` in a new GUI terminal window.

        Detection order:
          macOS:  iTerm.app (if $TERM_PROGRAM=iTerm.app) → Terminal.app
          Linux:  gnome-terminal → konsole → xterm
        Returns True if a window was successfully spawned, False otherwise.
        On False, the caller falls back to take-over-current-shell.
        """
        term_program = os.environ.get("TERM_PROGRAM", "")

        if sys.platform == "darwin":
            # iTerm2: prefer when operator is already using it.
            if term_program == "iTerm.app":
                script = (
                    'tell application "iTerm" to create window '
                    f'with default profile command "{attach_cmd}"'
                )
                r = subprocess.run(
                    ["osascript", "-e", script], capture_output=True,
                )
                if r.returncode == 0:
                    return True
                # Fall through to Terminal.app on any iTerm scripting error.

            # Terminal.app: always present on macOS.
            r = subprocess.run(
                ["osascript", "-e",
                 f'tell application "Terminal" to do script "{attach_cmd}"'],
                capture_output=True,
            )
            return r.returncode == 0

        # Linux: try common terminals in order of preference.
        for term_cmd, term_args in (
            ("gnome-terminal", ["--", "bash", "-c", attach_cmd]),
            ("konsole",        ["-e", "bash", "-c", attach_cmd]),
            ("xterm",          ["-e", attach_cmd]),
        ):
            if _shutil.which(term_cmd):
                try:
                    # Popen (not run) — don't wait for the window to close.
                    subprocess.Popen([term_cmd, *term_args])
                    return True
                except (OSError, FileNotFoundError):
                    continue
        return False

    def _switch_or_attach() -> None:
        """Hand off control to the deploy session — prefer a NEW window.

        Three strategies, in order:
          1. Try to open a NEW GUI terminal window running `tmux attach`.
             This is the primary path on macOS / desktop Linux. It works
             whether or not the operator is already inside tmux — the new
             window starts a fresh tmux client outside the current pane,
             so the operator's existing tmux session is untouched.
          2. If no GUI terminal is available BUT we're inside a tmux
             client, `tmux switch-client -t <session>` (changes the
             current client's view; the only sensible move in pure-tmux
             headless contexts).
          3. Else `tmux attach` in the current shell (SSH / no-tmux).
        """
        attach_cmd = f"tmux attach -t {session_name}"
        if _open_new_window(attach_cmd):
            print(f"  Opened a new terminal window attached to {session_name}.")
            return

        if inside_tmux:
            # GUI spawn failed but we are inside tmux. switch-client is
            # the only way to actually show the session to the operator.
            print(f"  No GUI terminal detected; switching tmux client to "
                  f"{session_name}.")
            subprocess.run(
                ["tmux", "switch-client", "-t", session_name],
                check=False,
            )
            return

        # No GUI terminal and not inside tmux — take over the current
        # shell so the operator at least sees the session immediately.
        print(f"  No GUI terminal detected; attaching in current shell.")
        os.execvp("tmux", ["tmux", "attach", "-t", session_name])

    # 5. Check if the session already exists.
    existing = subprocess.run(
        ["tmux", "has-session", "-t", session_name],
        capture_output=True,
    )
    session_exists = existing.returncode == 0

    if session_exists:
        # Send the new /deploy into the running session — queues more work
        # without restarting Claude (preserves context, in-flight state).
        print(f"Session '{session_name}' already running — queueing new command.")
        print(f"  Repo:    {args.repo} → {target_repo}")
        print(f"  Sending: {slash_cmd}")
        subprocess.run(
            ["tmux", "send-keys", "-t", session_name, slash_cmd, "Enter"],
            check=True,
        )
        if attach:
            _switch_or_attach()
        else:
            print(f"  Attach:  tmux attach -t {session_name}")
        return

    # 6. New session: create detached, start claude, wait, send command.
    subprocess.run(
        ["tmux", "new-session", "-d", "-s", session_name, "-c", target_repo],
        check=True,
    )
    subprocess.run(
        ["tmux", "send-keys", "-t", session_name, "claude", "Enter"],
        check=True,
    )
    # Sleep matches the prior `se o start` heuristic — 3s gives Claude
    # time to initialise before its stdin is fed the first command.
    _time.sleep(3)
    subprocess.run(
        ["tmux", "send-keys", "-t", session_name, slash_cmd, "Enter"],
        check=True,
    )

    print("Deploy session started.")
    print(f"  Session: {session_name}")
    print(f"  Repo:    {args.repo} → {target_repo}")
    print(f"  Command: {slash_cmd}")
    if attach:
        # Print before handing off — output lands in the operator's
        # scrollback if the new-window path fails and we take over the
        # current shell.
        print(f"  Opening attach in new window… "
              f"(Ctrl+B d to detach later, "
              f"`tmux kill-session -t {session_name}` to stop)")
        _switch_or_attach()
    else:
        print(f"  Attach:  tmux attach -t {session_name}")
        print(f"  Kill:    tmux kill-session -t {session_name}")


