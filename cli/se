# ── se orchestrator ───────────────────────────────────────────────────────────
#
# Thin wrappers around agents/orchestrator/cli/*.py.  Each script's main()
# was refactored to accept argv: list[str] | None for in-process dispatch
# (same pattern as cmd_taskgen / cmd_plane_sync, PyInstaller-friendly).
#
# Subcommand tree:
#   se orchestrator route       <id>
#   se orchestrator doctor
#   se orchestrator fix-bug claim   <id>
#   se orchestrator fix-bug verify  <id>
#   se orchestrator fix-bug pr      <id>
#   se orchestrator qa load     <id> [--type ...]
#   se orchestrator qa report   <id> --results-file ...
#   se orchestrator deploy      [<id>] [--team T]  # route + Phase 0 entry
#
# `deploy` is the operator's "start orchestrator" entry: routes a single
# issue (or auto-picks one) and kicks off the team's Phase 0 step.
# Multi-phase pipelines (fix-bug, QA) still need human-in-loop between
# phases — `deploy` only fires the first step.


_ORCH_SCRIPT_DIR = ("agents", "orchestrator", "cli")


# Teams that have a Phase 0 dispatch script (an "agent") and can be looped
# in `se o deploy --all` for real Phase 0 dispatch.
_AGENT_TEAMS: tuple[str, ...] = ("fix-bug", "qa", "task-generator", "epic-task")

# Teams that only produce a /ship hint per issue (no `se`-side Phase 0 script).
# epic-task now has epic_task_claim.py, so this is empty.
_HINT_ONLY_TEAMS: tuple[str, ...] = ()

# Union: every team `--all --team T` will iterate. Anything outside this
# tuple is rejected with a "not a valid batch target" message + exit 0.
_BATCH_TEAMS: tuple[str, ...] = _AGENT_TEAMS + _HINT_ONLY_TEAMS


def _add_plane_profile_flags(p: argparse.ArgumentParser) -> None:
    """Attach `--plane-profile NAME` and `--plane-config PATH` to a subparser.

    Both flags are alternatives to setting PLANE_PROFILE / PLANE_CONFIG in
    the shell environment before calling `se`. The `_apply_plane_profile_env`
    helper translates them into the same env vars right before dispatching
    the underlying script, so the resolver in plane_client / grava_plane_sync
    / orchestrator's doctor.py picks them up uniformly.

    Use on every `se` subparser whose dispatched script ends up reading
    Plane credentials (taskgen, plane-sync, `o doctor`, `o expand`,
    `o deploy`).
    """
    p.add_argument(
        "--plane-profile", default=None, metavar="NAME",
        help="Load creds from ~/.config/plane/<NAME>.json instead of the "
             "default config.json. Equivalent to PLANE_PROFILE env var.",
    )
    p.add_argument(
        "--plane-config", default=None, metavar="PATH",
        help="Load creds from an explicit JSON file path. Overrides "
             "--plane-profile and PLANE_PROFILE. Equivalent to PLANE_CONFIG "
             "env var.",
    )


def _apply_plane_profile_env(args: argparse.Namespace) -> None:
    """Translate --plane-profile / --plane-config flags to env vars.

    Underlying scripts (plane_client.load_credentials, grava_plane_sync's
    plane_configured, orchestrator/cli/doctor.check_plane_creds) read
    PLANE_CONFIG and PLANE_PROFILE from os.environ. Setting them here
    before dispatching the script (either in-process via _load_module or
    in a subprocess inheriting environ) is enough to redirect them at
    a different profile without changing any caller code downstream.

    Precedence inside the underlying loader is:
      PLANE_CONFIG  > PLANE_PROFILE  > default ~/.config/plane/config.json
    so setting both here is fine — PLANE_CONFIG wins by design.
    """
    profile = getattr(args, "plane_profile", None)
    config_path = getattr(args, "plane_config", None)
    if profile:
        os.environ["PLANE_PROFILE"] = profile
    if config_path:
        os.environ["PLANE_CONFIG"] = config_path


def _orch_script(name: str) -> Path:
    """Resolve agents/orchestrator/cli/<name>.py inside the bundle / source tree."""
    return _repo_root().joinpath(*_ORCH_SCRIPT_DIR, name)


def _orch_invoke(script_name: str, mod_name: str, argv: list[str]) -> int:
    """Load orch script and call its main(argv)."""
    script = _orch_script(script_name)
    if not script.exists():
        print(f"ERROR: {script} not found", file=sys.stderr)
        return 1
    mod = _load_module(mod_name, script)
    return mod.main(argv)


