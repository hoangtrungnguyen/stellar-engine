# ── repos.yaml I/O ────────────────────────────────────────────────────────────


def _load_repos(base: Path) -> dict[str, dict]:
    path = base / "repos.yaml"
    if not path.exists():
        return {}
    data = yaml.safe_load(path.read_text()) or {}
    return data.get("repos") or {}


def _resolve_named_repo(name: str, base: Path) -> Path:
    """Resolve a repo NAME → absolute path via repos.yaml.

    Raises SystemExit(2) with a helpful message if the name is not registered
    or repos.yaml is missing. Used by `se o deploy --repo NAME` (and any
    other operator command that should refuse to operate on unregistered
    repos — name-based addressing prevents typos and stops the operator
    from deploying to the wrong directory).
    """
    repos = _load_repos(base)
    if not repos:
        print(
            f"ERROR: no repos registered. repos.yaml not found at {base}/repos.yaml "
            f"or empty.\n"
            f"Fix: `se init --dir {base}` then `se repos add <name> --path <abs-path>`.",
            file=sys.stderr,
        )
        sys.exit(2)
    if name not in repos:
        registered = ", ".join(sorted(repos.keys())) or "(none)"
        print(
            f"ERROR: repo '{name}' not registered in repos.yaml.\n"
            f"Registered repos: {registered}\n"
            f"Fix: `se repos add {name} --path <abs-path>` or check spelling.",
            file=sys.stderr,
        )
        sys.exit(2)
    entry = repos[name]
    path_str = entry.get("path") if isinstance(entry, dict) else None
    if not path_str:
        print(
            f"ERROR: repo '{name}' has no path in repos.yaml.\n"
            f"Fix: edit repos.yaml and set `repos.{name}.path: <abs-path>`.",
            file=sys.stderr,
        )
        sys.exit(2)
    repo_path = Path(path_str).expanduser().resolve()
    if not repo_path.is_dir():
        print(
            f"ERROR: repo '{name}' path {repo_path} does not exist or is not a directory.\n"
            f"Fix: check the path in repos.yaml.",
            file=sys.stderr,
        )
        sys.exit(2)
    return repo_path


